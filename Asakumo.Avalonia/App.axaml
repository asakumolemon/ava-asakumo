<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Asakumo.Avalonia"
             x:Class="Asakumo.Avalonia.App"
             RequestedThemeVariant="Default">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <!-- 色彩系统 - 基于 OpenAI 风格 -->
    <Application.Resources>
        <ResourceDictionary>
            <!-- 品牌色 -->
            <Color x:Key="BrandPrimaryColor">#10A37F</Color>
            <Color x:Key="BrandSecondaryColor">#0D8A6A</Color>
            <Color x:Key="BrandAccentColor">#1A7F64</Color>
            
            <!-- 浅色主题 -->
            <SolidColorBrush x:Key="PrimaryBrush" Color="#10A37F"/>
            <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#0D8A6A"/>
            <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#1A7F64"/>
            
            <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="SurfaceVariantBrush" Color="#F3F4F6"/>
            <SolidColorBrush x:Key="SurfaceCardBrush" Color="#FFFFFF"/>
            
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1F2937"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6B7280"/>
            <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="#FFFFFF"/>
            
            <SolidColorBrush x:Key="BorderBrush" Color="#E5E7EB"/>
            <SolidColorBrush x:Key="DividerBrush" Color="#F3F4F6"/>
            
            <!-- 发送消息气泡色 -->
            <SolidColorBrush x:Key="UserMessageBrush" Color="#10A37F"/>
            
            <!-- 错误色 -->
            <SolidColorBrush x:Key="ErrorBrush" Color="#EF4444"/>
            <SolidColorBrush x:Key="ErrorBackgroundBrush" Color="#FEF2F2"/>
            <SolidColorBrush x:Key="ErrorBorderBrush" Color="#FECACA"/>
            
            <!-- 成功色 -->
            <SolidColorBrush x:Key="SuccessBrush" Color="#10B981"/>
            
            <!-- 深色主题覆盖 -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#F3F4F6"/>
                    <SolidColorBrush x:Key="AppCardBrush" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="AppTextPrimaryBrush" Color="#1F2937"/>
                    <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="#6B7280"/>
                    <SolidColorBrush x:Key="AppBorderBrush" Color="#E5E7EB"/>
                    <SolidColorBrush x:Key="AppDividerBrush" Color="#F3F4F6"/>
                    <SolidColorBrush x:Key="AppUserMessageBrush" Color="#10A37F"/>
                    <SolidColorBrush x:Key="AppAiMessageBrush" Color="#F3F4F6"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#1A1A1A"/>
                    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#2D2D2D"/>
                    <SolidColorBrush x:Key="AppCardBrush" Color="#2D2D2D"/>
                    <SolidColorBrush x:Key="AppTextPrimaryBrush" Color="#F3F4F6"/>
                    <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="#9CA3AF"/>
                    <SolidColorBrush x:Key="AppBorderBrush" Color="#404040"/>
                    <SolidColorBrush x:Key="AppDividerBrush" Color="#2D2D2D"/>
                    <SolidColorBrush x:Key="AppUserMessageBrush" Color="#10A37F"/>
                    <SolidColorBrush x:Key="AppAiMessageBrush" Color="#2D2D2D"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        
        <!-- 主按钮样式 -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#10A37F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="CornerRadius" Value="25"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="ScaleTransform.ScaleX" Duration="0:0:0.1"/>
                    <DoubleTransition Property="ScaleTransform.ScaleY" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
            <Setter Property="RenderTransform">
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#0D8A6A"/>
            <Style.Animations>
                <Animation Duration="0:0:0.15" FillMode="Forward">
                    <KeyFrame Cue="0%">
                        <Setter Property="Background" Value="#10A37F"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Background" Value="#0D8A6A"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Button.primary:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1A7F64"/>
            <Style.Animations>
                <Animation Duration="0:0:0.08" FillMode="Forward">
                    <KeyFrame Cue="0%">
                        <Setter Property="Background" Value="#0D8A6A"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Background" Value="#1A7F64"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Button.primary:pressed">
            <Setter Property="ScaleTransform.ScaleX" Value="0.97"/>
            <Setter Property="ScaleTransform.ScaleY" Value="0.97"/>
        </Style>
        <Style Selector="Button.primary:disabled">
            <Setter Property="Opacity" Value="0.5"/>
        </Style>
        
        <!-- 次要按钮样式 -->
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="ScaleTransform.ScaleX" Duration="0:0:0.1"/>
                    <DoubleTransition Property="ScaleTransform.ScaleY" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
            <Setter Property="RenderTransform">
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        </Style>
        <Style Selector="Button.secondary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Style.Animations>
                <Animation Duration="0:0:0.15" FillMode="Forward">
                    <KeyFrame Cue="0%">
                        <Setter Property="Background" Value="#F3F4F6"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Background" Value="#E5E7EB"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Button.secondary:pressed">
            <Setter Property="ScaleTransform.ScaleX" Value="0.97"/>
            <Setter Property="ScaleTransform.ScaleY" Value="0.97"/>
        </Style>
        
        <!-- 卡片样式 -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource AppCardBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
        
        <!-- Chip 样式 -->
        <Style Selector="Border.chip">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        
        <!-- 小标签 Chip 样式 -->
        <Style Selector="Border.tag">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="6,2"/>
        </Style>
        
        <!-- 发送按钮样式 -->
        <Style Selector="Button.send">
            <Setter Property="Background" Value="#10A37F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="ScaleTransform.ScaleX" Duration="0:0:0.1"/>
                    <DoubleTransition Property="ScaleTransform.ScaleY" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
            <Setter Property="RenderTransform">
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        </Style>
        <Style Selector="Button.send:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#0D8A6A"/>
            <Style.Animations>
                <Animation Duration="0:0:0.15" FillMode="Forward">
                    <KeyFrame Cue="0%">
                        <Setter Property="Background" Value="#10A37F"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Background" Value="#0D8A6A"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Button.send:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1A7F64"/>
            <Style.Animations>
                <Animation Duration="0:0:0.08" FillMode="Forward">
                    <KeyFrame Cue="0%">
                        <Setter Property="Background" Value="#0D8A6A"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Background" Value="#1A7F64"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Button.send:pressed">
            <Setter Property="ScaleTransform.ScaleX" Value="0.95"/>
            <Setter Property="ScaleTransform.ScaleY" Value="0.95"/>
        </Style>
        <Style Selector="Button.send:disabled">
            <Setter Property="Opacity" Value="0.5"/>
        </Style>
        
        <!-- FAB 悬浮按钮样式 -->
        <Style Selector="Button.fab">
            <Setter Property="Background" Value="#10A37F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="28"/>
            <Setter Property="Width" Value="56"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="ScaleTransform.ScaleX" Duration="0:0:0.15"/>
                    <DoubleTransition Property="ScaleTransform.ScaleY" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
            <Setter Property="RenderTransform">
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        </Style>
        <Style Selector="Button.fab:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#0D8A6A"/>
            <Style.Animations>
                <Animation Duration="0:0:0.15" FillMode="Forward">
                    <KeyFrame Cue="0%">
                        <Setter Property="Background" Value="#10A37F"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Background" Value="#0D8A6A"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Button.fab:pointerover">
            <Setter Property="ScaleTransform.ScaleX" Value="1.05"/>
            <Setter Property="ScaleTransform.ScaleY" Value="1.05"/>
        </Style>
        <Style Selector="Button.fab:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1A7F64"/>
            <Style.Animations>
                <Animation Duration="0:0:0.08" FillMode="Forward">
                    <KeyFrame Cue="0%">
                        <Setter Property="Background" Value="#0D8A6A"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Background" Value="#1A7F64"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Button.fab:pressed">
            <Setter Property="ScaleTransform.ScaleX" Value="0.95"/>
            <Setter Property="ScaleTransform.ScaleY" Value="0.95"/>
        </Style>
        
        <!-- 图标按钮样式 -->
        <Style Selector="Button.icon">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="ScaleTransform.ScaleX" Duration="0:0:0.1"/>
                    <DoubleTransition Property="ScaleTransform.ScaleY" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
            <Setter Property="RenderTransform">
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        </Style>
        <Style Selector="Button.icon:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Style.Animations>
                <Animation Duration="0:0:0.15" FillMode="Forward">
                    <KeyFrame Cue="0%">
                        <Setter Property="Background" Value="Transparent"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Background" Value="#F3F4F6"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Button.icon:pressed">
            <Setter Property="ScaleTransform.ScaleX" Value="0.9"/>
            <Setter Property="ScaleTransform.ScaleY" Value="0.9"/>
        </Style>
        
        <!-- 输入框样式 -->
        <Style Selector="TextBox.chat-input">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="MaxHeight" Value="120"/>
        </Style>
        
        <!-- 页面标题样式 -->
        <Style Selector="TextBlock.page-title">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
        </Style>
        
        <!-- 章节标题样式 -->
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}"/>
        </Style>
        
        <!-- 正文样式 -->
        <Style Selector="TextBlock.body">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
        </Style>
        
        <!-- 说明文字样式 -->
        <Style Selector="TextBlock.caption">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}"/>
        </Style>
        
        <!-- 时间戳样式 -->
        <Style Selector="TextBlock.timestamp">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}"/>
        </Style>
        
        <!-- 打字动画容器 -->
        <Style Selector="StackPanel.typing-indicator">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Spacing" Value="4"/>
        </Style>
        
        <!-- 打字动画点 -->
        <Style Selector="Border.typing-dot">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="{DynamicResource AppTextSecondaryBrush}"/>
        </Style>
        <Style Selector="Border.typing-dot:animated">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.4"/>
                </Transitions>
            </Setter>
        </Style>
    </Application.Styles>
    
    <!-- 打字动画定义 -->
    <Application.Styles>
        <Style Selector="Border.typing-dot:nth-child(1)">
            <Style.Animations>
                <Animation Duration="0:0:1.2" IterationCount="Infinite">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0.3"/>
                    </KeyFrame>
                    <KeyFrame Cue="16%">
                        <Setter Property="Opacity" Value="1"/>
                    </KeyFrame>
                    <KeyFrame Cue="33%">
                        <Setter Property="Opacity" Value="0.3"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="0.3"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Border.typing-dot:nth-child(2)">
            <Style.Animations>
                <Animation Duration="0:0:1.2" IterationCount="Infinite">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0.3"/>
                    </KeyFrame>
                    <KeyFrame Cue="33%">
                        <Setter Property="Opacity" Value="0.3"/>
                    </KeyFrame>
                    <KeyFrame Cue="49%">
                        <Setter Property="Opacity" Value="1"/>
                    </KeyFrame>
                    <KeyFrame Cue="66%">
                        <Setter Property="Opacity" Value="0.3"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="0.3"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Border.typing-dot:nth-child(3)">
            <Style.Animations>
                <Animation Duration="0:0:1.2" IterationCount="Infinite">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0.3"/>
                    </KeyFrame>
                    <KeyFrame Cue="66%">
                        <Setter Property="Opacity" Value="0.3"/>
                    </KeyFrame>
                    <KeyFrame Cue="82%">
                        <Setter Property="Opacity" Value="1"/>
                    </KeyFrame>
                    <KeyFrame Cue="99%">
                        <Setter Property="Opacity" Value="0.3"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="0.3"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </Application.Styles>
</Application>
