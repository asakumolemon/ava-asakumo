<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Asakumo.Avalonia.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="600"
             x:Class="Asakumo.Avalonia.Views.ModelSelectorView"
             x:DataType="vm:ModelSelectorViewModel"
             Background="{DynamicResource AppBackgroundBrush}">

  <Grid RowDefinitions="Auto, Auto, *, Auto">
    <!-- Header -->
    <Border Grid.Row="0"
            Background="{DynamicResource AppBackgroundBrush}"
            Height="64"
            Padding="16,0">
      <Grid ColumnDefinitions="Auto, *, Auto">
        <Button Grid.Column="0"
                Command="{Binding CloseCommand}"
                Classes="icon"
                VerticalAlignment="Center"
                ToolTip.Tip="关闭">
          <PathIcon Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                    Width="24" Height="24"/>
        </Button>

        <TextBlock Grid.Column="1"
                   Text="选择模型"
                   FontSize="20"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Foreground="{DynamicResource AppTextPrimaryBrush}"/>

        <Button Grid.Column="2"
                Command="{Binding RefreshModelsCommand}"
                Classes="icon"
                VerticalAlignment="Center"
                ToolTip.Tip="刷新模型列表">
          <PathIcon Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"
                    Width="22" Height="22"/>
        </Button>
      </Grid>
    </Border>

    <!-- Search Box -->
    <Border Grid.Row="1"
            Background="{DynamicResource AppSurfaceBrush}"
            CornerRadius="24"
            Padding="16,8"
            Margin="16,8">
      <Grid ColumnDefinitions="Auto, *, Auto">
        <PathIcon Grid.Column="0"
                  Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"
                  Width="20" Height="20"
                  Foreground="{DynamicResource AppTextSecondaryBrush}"/>
        <TextBox Grid.Column="1"
                 Text="{Binding SearchQuery}"
                 Watermark="搜索模型..."
                 Background="Transparent"
                 BorderThickness="0"
                 VerticalAlignment="Center"
                 Margin="8,0"/>
        <Button Grid.Column="2"
                Command="{Binding ClearSearchCommand}"
                Classes="icon"
                IsVisible="{Binding SearchQuery, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
          <PathIcon Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                    Width="16" Height="16"/>
        </Button>
      </Grid>
    </Border>

    <!-- Content -->
    <ScrollViewer Grid.Row="2" Margin="16,0">
      <StackPanel Spacing="16">
        <!-- Loading Indicator -->
        <StackPanel IsVisible="{Binding IsLoading}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12"
                    Margin="0,40">
          <ProgressBar IsIndeterminate="True"
                       Width="40" Height="40"/>
          <TextBlock Text="加载模型列表..."
                     Foreground="{DynamicResource AppTextSecondaryBrush}"/>
        </StackPanel>

        <!-- Recent Models Section -->
        <StackPanel IsVisible="{Binding HasRecentModels}"
                    Spacing="8">
          <TextBlock Text="最近使用"
                     FontSize="14"
                     FontWeight="Medium"
                     Foreground="{DynamicResource AppTextSecondaryBrush}"
                     Margin="0,0,0,8"/>

          <ItemsControl ItemsSource="{Binding RecentModels}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:ModelSelectorItemViewModel">
                <Button Command="{Binding $parent[ItemsControl].((vm:ModelSelectorViewModel)DataContext).SelectModelCommand}"
                        CommandParameter="{Binding}"
                        Background="{DynamicResource AppCardBrush}"
                        BorderThickness="0"
                        Padding="12,10"
                        Margin="0,0,0,6"
                        CornerRadius="10"
                        HorizontalAlignment="Stretch">
                  <Grid ColumnDefinitions="Auto, *, Auto">
                    <Border Grid.Column="0"
                            Width="32" Height="32"
                            CornerRadius="16"
                            Background="{DynamicResource PrimaryBrush}">
                      <PathIcon Data="{Binding Icon}"
                                Width="16" Height="16"
                                Foreground="White"/>
                    </Border>
                    <StackPanel Grid.Column="1"
                                Margin="12,0"
                                VerticalAlignment="Center">
                      <TextBlock Text="{Binding DisplayName}"
                                 FontSize="14"
                                 FontWeight="Medium"
                                 Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                      <TextBlock Text="{Binding ProviderName}"
                                 FontSize="11"
                                 Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                    </StackPanel>
                    <PathIcon Grid.Column="2"
                              Data="M9,16.17L4.83,12L3.41,13.41L9,19L21,7L19.59,5.59L9,16.17Z"
                              Width="18" Height="18"
                              Foreground="{DynamicResource SuccessBrush}"
                              IsVisible="{Binding IsCurrent}"/>
                  </Grid>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <!-- Provider Groups -->
        <ItemsControl ItemsSource="{Binding ProviderGroups}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:ProviderGroupViewModel">
              <StackPanel Spacing="8"
                          IsVisible="{Binding IsVisible}">
                <!-- Provider Header -->
                <Button Command="{Binding ToggleExpandCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0,8"
                        HorizontalAlignment="Stretch">
                  <Grid ColumnDefinitions="Auto, *, Auto">
                    <Border Grid.Column="0"
                            Width="24" Height="24"
                            CornerRadius="12"
                            Background="{DynamicResource AppSurfaceBrush}">
                      <PathIcon Data="{Binding Icon}"
                                Width="14" Height="14"
                                Foreground="{DynamicResource PrimaryBrush}"/>
                    </Border>
                    <TextBlock Grid.Column="1"
                               Text="{Binding ProviderName}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextPrimaryBrush}"
                               VerticalAlignment="Center"
                               Margin="8,0"/>
                    <PathIcon Grid.Column="2"
                              Data="M7,10L12,15L17,10H7Z"
                              Width="16" Height="16"
                              Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                  </Grid>
                </Button>

                <!-- Models List -->
                <ItemsControl ItemsSource="{Binding Models}"
                              IsVisible="{Binding IsExpanded}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ModelSelectorItemViewModel">
                      <Button Command="{Binding $parent[ItemsControl].((vm:ModelSelectorViewModel)DataContext).SelectModelCommand}"
                              CommandParameter="{Binding}"
                              Background="{DynamicResource AppSurfaceBrush}"
                              BorderThickness="0"
                              Padding="12,10"
                              Margin="24,0,0,6"
                              CornerRadius="8"
                              HorizontalAlignment="Stretch"
                              IsVisible="{Binding IsVisible}">
                        <Grid ColumnDefinitions="*, Auto">
                          <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="{Binding ModelName}"
                                       FontSize="13"
                                       Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                            <TextBlock Text="{Binding Description}"
                                       FontSize="11"
                                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                          </StackPanel>
                          <PathIcon Grid.Column="1"
                                    Data="M9,16.17L4.83,12L3.41,13.41L9,19L21,7L19.59,5.59L9,16.17Z"
                                    Width="16" Height="16"
                                    Foreground="{DynamicResource PrimaryBrush}"
                                    IsVisible="{Binding IsCurrent}"/>
                        </Grid>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Empty State -->
        <StackPanel IsVisible="{Binding !HasProviderGroups}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12"
                    Margin="0,40">
          <PathIcon Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4Z"
                    Width="48" Height="48"
                    Foreground="{DynamicResource AppTextSecondaryBrush}"/>
          <TextBlock Text="没有可用的模型"
                     FontSize="16"
                     Foreground="{DynamicResource AppTextSecondaryBrush}"/>
          <TextBlock Text="请先配置并启用至少一个供应商"
                     FontSize="12"
                     Foreground="{DynamicResource AppTextSecondaryBrush}"/>
        </StackPanel>
      </StackPanel>
    </ScrollViewer>

    <!-- Footer -->
    <Border Grid.Row="3"
            Background="{DynamicResource AppSurfaceBrush}"
            Padding="16"
            Margin="0,8,0,0">
      <Button Command="{Binding ManageProvidersCommand}"
              Classes="secondary"
              HorizontalAlignment="Stretch"
              Height="44"
              CornerRadius="22">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <PathIcon Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                    Width="18" Height="18"/>
          <TextBlock Text="管理供应商配置"
                     FontWeight="Medium"/>
        </StackPanel>
      </Button>
    </Border>
  </Grid>
</UserControl>
