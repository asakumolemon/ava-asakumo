<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Asakumo.Avalonia.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:Class="Asakumo.Avalonia.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             Background="{DynamicResource AppBackgroundBrush}">

  <Grid RowDefinitions="Auto, *">
    <!-- Toast Notification -->
    <Border Grid.Row="0" Grid.RowSpan="2"
            Background="#333333"
            CornerRadius="8"
            Padding="16,10"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="0,0,0,40"
            IsVisible="{Binding ShowToast}"
            ZIndex="200"
            Opacity="0.9">
      <TextBlock Text="{Binding ToastMessage}"
                 Foreground="White"
                 FontSize="14"/>
    </Border>

    <!-- Clear All Data Confirmation Dialog -->
    <Border Grid.Row="0" Grid.RowSpan="2"
            Background="#80000000"
            IsVisible="{Binding ShowClearDataConfirmDialog}"
            ZIndex="300">
      <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <Border Background="{DynamicResource AppCardBrush}"
                CornerRadius="16"
                Padding="24"
                Width="320"
                BoxShadow="0 4 16 0 #40000000">
          <StackPanel Spacing="16">
            <!-- Icon -->
            <PathIcon Data="M13,9H11V7H13M13,17H11V11H13M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,0 4,12C4,16.42 7.58,20 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M13,7H11V13H13V7M13,15H11V17H13V15Z"
                        Width="48" Height="48"
                        HorizontalAlignment="Center"
                        Foreground="{DynamicResource ErrorBrush}"/>

            <!-- Title -->
            <TextBlock Text="清除所有数据？"
                       FontSize="18"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource AppTextPrimaryBrush}"/>

            <!-- Message -->
            <TextBlock Text="此操作将永久删除所有会话、消息、API 密钥和设置。此操作无法撤销，应用将自动重启。"
                       FontSize="14"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="12">
              <Button Content="取消"
                      Command="{Binding CancelClearAllDataCommand}"
                      Width="100"
                      Height="40"
                      CornerRadius="20"/>
              <Button Content="确认清除"
                      Command="{Binding ConfirmClearAllDataCommand}"
                      Background="{DynamicResource ErrorBrush}"
                      Foreground="White"
                      Width="100"
                      Height="40"
                      CornerRadius="20"/>
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <!-- Header -->
    <Border Grid.Row="0"
            Background="{DynamicResource AppBackgroundBrush}"
            Height="64"
            Padding="16,0">
      <Grid ColumnDefinitions="Auto, *, Auto">
        <Button Grid.Column="0"
                Command="{Binding GoBackCommand}"
                Classes="icon"
                VerticalAlignment="Center"
                ToolTip.Tip="返回">
          <PathIcon Data="M20,11H7.83L13.42,5.41L12,4L4,12L12,20L13.41,18.59L7.83,13H20V11Z"
                    Width="24" Height="24"/>
        </Button>

        <TextBlock Grid.Column="1"
                   Text="设置"
                   FontSize="20"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource AppTextPrimaryBrush}"/>

        <Border Grid.Column="2" Width="40"/>
      </Grid>
    </Border>

    <!-- Content -->
    <ScrollViewer Grid.Row="1"
                  Background="{DynamicResource AppBackgroundBrush}">
      <StackPanel Spacing="16" Margin="16">

        <!-- AI Services Section -->
        <StackPanel Spacing="8">
          <TextBlock Text="AI 服务"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource AppTextSecondaryBrush}"/>

          <!-- Current Model Card -->
          <Border Background="{DynamicResource PrimaryBrush}"
                  CornerRadius="12"
                  Padding="16"
                  IsVisible="{Binding IsProviderConfigured}">
            <Grid ColumnDefinitions="Auto, *, Auto">
              <Border Grid.Column="0"
                      Width="40" Height="40"
                      CornerRadius="20"
                      Background="White"
                      Opacity="0.2">
                <PathIcon Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M12,6A6,6 0 0,1 18,12A6,6 0 0,1 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6Z"
                          Width="24" Height="24"
                          Foreground="White"/>
              </Border>
              <StackPanel Grid.Column="1"
                          Margin="12,0"
                          VerticalAlignment="Center">
                <TextBlock Text="当前模型"
                           FontSize="12"
                           Opacity="0.8"
                           Foreground="White"/>
                <TextBlock Text="{Binding CurrentModelName}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="White"/>
                <TextBlock Text="{Binding CurrentProviderName}"
                           FontSize="12"
                           Opacity="0.7"
                           Foreground="White"/>
              </StackPanel>
              <Border Grid.Column="2"
                      Width="24" Height="24"
                      CornerRadius="12"
                      Background="White"
                      VerticalAlignment="Center">
                <PathIcon Data="M9,16.17L4.83,12L3.41,13.41L9,19L21,7L19.59,5.59L9,16.17Z"
                          Width="16" Height="16"
                          Foreground="{DynamicResource PrimaryBrush}"/>
              </Border>
            </Grid>
          </Border>

          <!-- AI Services Entry -->
          <Border Background="{DynamicResource AppCardBrush}"
                  CornerRadius="12">
            <Button Command="{Binding ManageProvidersCommand}"
                    Background="Transparent"
                    BorderThickness="0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left">
              <Border Padding="12">
                <Grid ColumnDefinitions="Auto, *, Auto">
                  <PathIcon Grid.Column="0"
                            Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M12,6A6,6 0 0,1 18,12A6,6 0 0,1 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6Z"
                            Width="20" Height="20"
                            Margin="0,0,12,0"
                            Foreground="{DynamicResource PrimaryBrush}"/>
                  <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="供应商管理"
                               Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                    <TextBlock Text="{Binding ConfiguredProviderCount, StringFormat='已配置 {0} 个供应商'}"
                               FontSize="12"
                               Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                  </StackPanel>
                  <PathIcon Grid.Column="2"
                            Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z"
                            Width="20" Height="20"
                            Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                </Grid>
              </Border>
            </Button>
          </Border>
        </StackPanel>

        <!-- Models Section -->
        <StackPanel Spacing="8" IsVisible="{Binding HasModels}">
          <TextBlock Text="可用模型"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource AppTextSecondaryBrush}"/>
          <Border Background="{DynamicResource AppCardBrush}"
                  CornerRadius="12">
            <ItemsControl ItemsSource="{Binding AllModels}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:SettingsModelItemViewModel">
                  <Button Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).SelectModelCommand}"
                          CommandParameter="{Binding}"
                          Background="Transparent"
                          BorderThickness="0"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Left"
                          Padding="12,10">
                    <Grid ColumnDefinitions="Auto, *, Auto">
                      <!-- Provider Icon -->
                      <Border Grid.Column="0"
                              Width="28" Height="28"
                              CornerRadius="14"
                              Background="{DynamicResource AppSurfaceBrush}"
                              VerticalAlignment="Center">
                        <TextBlock Text="{Binding ProviderInitial}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource PrimaryBrush}"/>
                      </Border>
                      
                      <!-- Model Info -->
                      <StackPanel Grid.Column="1"
                                  Margin="12,0"
                                  VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="14"
                                   Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                        <TextBlock Text="{Binding ProviderName}"
                                   FontSize="11"
                                   Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                      </StackPanel>
                      
                      <!-- Current Indicator -->
                      <PathIcon Grid.Column="2"
                                Data="M9,16.17L4.83,12L3.41,13.41L9,19L21,7L19.59,5.59L9,16.17Z"
                                Width="16" Height="16"
                                Foreground="{DynamicResource SuccessBrush}"
                                IsVisible="{Binding IsCurrent}"/>
                    </Grid>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Border>
        </StackPanel>

        <!-- Appearance Section -->
        <StackPanel Spacing="8">
          <TextBlock Text="外观"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource AppTextSecondaryBrush}"/>
          <Border Background="{DynamicResource AppCardBrush}"
                  CornerRadius="12">
            <StackPanel>
              <!-- Dark Mode -->
              <Border Padding="12">
                <Grid ColumnDefinitions="Auto, *, Auto">
                  <PathIcon Grid.Column="0"
                            Data="M12,3C7.03,3 3,7.03 3,12C3,16.97 7.03,21 12,21C12.83,21 13.5,20.33 13.5,19.5C13.5,19.11 13.35,18.76 13.11,18.5C12.88,18.23 12.73,17.88 12.73,17.5C12.73,16.67 13.4,16 14.23,16H16.5C19,16 21,14 21,11.5C21,6.58 16.97,3 12,3M12,19C8.13,19 5,15.87 5,12C5,8.13 8.13,5 12,5C13.76,5 15.37,5.6 16.68,6.59C16.24,7.31 16,8.13 16,9C16,11.21 17.79,13 20,13V14C20,16.76 17.76,19 15,19H12Z"
                            Width="20" Height="20"
                            Margin="0,0,12,0"
                            Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                  <TextBlock Grid.Column="1"
                             Text="深色模式"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                  <ToggleSwitch Grid.Column="2"
                                IsChecked="{Binding IsDarkMode}"/>
                </Grid>
              </Border>

              <Separator Margin="52,0,0,0"
                         Background="{DynamicResource AppDividerBrush}"/>

              <!-- Language -->
              <Button Command="{Binding OpenLanguageSettingsCommand}"
                      Background="Transparent"
                      BorderThickness="0"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Left">
                <Border Padding="12">
                  <Grid ColumnDefinitions="Auto, *, Auto">
                    <PathIcon Grid.Column="0"
                              Data="M12.87,15.07L10.33,12.56L10.36,12.53C12.1,10.59 13.34,8.36 14.07,6H17V4H10V2H8V4H1V6H12.17C11.5,7.92 10.44,9.75 9,11.35C8.07,10.32 7.3,9.19 6.69,8H4.69C5.42,9.63 6.42,11.17 7.67,12.56L2.58,17.58L4,19L9,14L12.11,17.11L12.87,15.07M18.5,10H16.5L12,22H14L15.12,19H19.87L21,22H23L18.5,10M15.88,17L17.5,12.67L19.12,17H15.88Z"
                              Width="20" Height="20"
                              Margin="0,0,12,0"
                              Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                      <TextBlock Text="语言"
                                 Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                      <TextBlock Text="{Binding SelectedLanguage}"
                                 FontSize="12"
                                 Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                    </StackPanel>
                    <PathIcon Grid.Column="2"
                              Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z"
                              Width="20" Height="20"
                              Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                  </Grid>
                </Border>
              </Button>
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- Data Section -->
        <StackPanel Spacing="8">
          <TextBlock Text="数据"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource AppTextSecondaryBrush}"/>
          <Border Background="{DynamicResource AppCardBrush}"
                  CornerRadius="12">
            <StackPanel>
              <!-- Backup -->
              <Button Command="{Binding BackupCommand}"
                      Background="Transparent"
                      BorderThickness="0"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Left">
                <Border Padding="12">
                  <Grid ColumnDefinitions="Auto, *, Auto">
                    <PathIcon Grid.Column="0"
                              Data="M12,3C7.58,3 4,4.79 4,7C4,9.21 7.58,11 12,11C16.42,11 20,9.21 20,7C20,4.79 16.42,3 12,3M4,9V12C4,14.21 7.58,16 12,16C16.42,16 20,14.21 20,12V9C20,11.21 16.42,13 12,13C7.58,13 4,11.21 4,9M4,14V17C4,19.21 7.58,21 12,21C16.42,21 20,19.21 20,17V14C20,16.21 16.42,18 12,18C7.58,18 4,16.21 4,14Z"
                              Width="20" Height="20"
                              Margin="0,0,12,0"
                              Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                    <TextBlock Grid.Column="1"
                               Text="备份与恢复"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                    <PathIcon Grid.Column="2"
                              Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z"
                              Width="20" Height="20"
                              Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                  </Grid>
                </Border>
              </Button>

              <Separator Margin="52,0,0,0"
                         Background="{DynamicResource AppDividerBrush}"/>

              <!-- Clear Data -->
              <Button Command="{Binding ClearConversationsCommand}"
                      Background="Transparent"
                      BorderThickness="0"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Left">
                <Border Padding="12">
                  <Grid ColumnDefinitions="Auto, *, Auto">
                    <PathIcon Grid.Column="0"
                              Data="M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19M8,9H16V19H8V9M15.5,4L14.5,3H9.5L8.5,4H5V6H19V4H15.5Z"
                              Width="20" Height="20"
                              Margin="0,0,12,0"
                              Foreground="{DynamicResource ErrorBrush}"/>
                    <TextBlock Grid.Column="1"
                               Text="清除所有会话"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource ErrorBrush}"/>
                    <PathIcon Grid.Column="2"
                              Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z"
                              Width="20" Height="20"
                              Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                  </Grid>
                </Border>
              </Button>

              <Separator Margin="52,0,0,0"
                         Background="{DynamicResource AppDividerBrush}"/>

              <!-- Clear All Data -->
              <Button Command="{Binding OpenClearDataDialogCommand}"
                      Background="Transparent"
                      BorderThickness="0"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Left">
                <Border Padding="12">
                  <Grid ColumnDefinitions="Auto, *, Auto">
                    <PathIcon Grid.Column="0"
                              Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19M12,9A4,4 0 0,1 16,13V17H14V13A2,2 0 0,0 12,11A2,2 0 0,0 10,13V17H8V13A4,4 0 0,1 12,9Z"
                              Width="20" Height="20"
                              Margin="0,0,12,0"
                              Foreground="{DynamicResource ErrorBrush}"/>
                    <StackPanel Grid.Column="1" Spacing="2">
                      <TextBlock Text="清除所有数据"
                                 VerticalAlignment="Center"
                                 Foreground="{DynamicResource ErrorBrush}"/>
                      <TextBlock Text="包括会话和设置，应用将重启"
                                 FontSize="11"
                                 Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                    </StackPanel>
                    <PathIcon Grid.Column="2"
                              Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12C4,16.42 7.58,20 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M13,7H11V13H13V7M13,15H11V17H13V15Z"
                              Width="20" Height="20"
                              Foreground="{DynamicResource ErrorBrush}"/>
                  </Grid>
                </Border>
              </Button>
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- About Section -->
        <StackPanel Spacing="8">
          <TextBlock Text="关于"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource AppTextSecondaryBrush}"/>
          <Border Background="{DynamicResource AppCardBrush}"
                  CornerRadius="12">
            <StackPanel>
              <!-- Version -->
              <Border Padding="12">
                <Grid ColumnDefinitions="Auto, *, Auto">
                  <PathIcon Grid.Column="0"
                            Data="M13,9H11V7H13M13,17H11V11H13M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2Z"
                            Width="20" Height="20"
                            Margin="0,0,12,0"
                            Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                  <TextBlock Grid.Column="1"
                             Text="版本 1.0.0"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                  <PathIcon Grid.Column="2"
                            Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z"
                            Width="20" Height="20"
                            Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                </Grid>
              </Border>

              <Separator Margin="52,0,0,0"
                         Background="{DynamicResource AppDividerBrush}"/>

              <!-- Privacy Policy -->
              <Border Padding="12">
                <Grid ColumnDefinitions="Auto, *, Auto">
                  <PathIcon Grid.Column="0"
                            Data="M12,17A2,2 0 0,1 14,19A2,2 0 0,1 12,21A2,2 0 0,1 10,19A2,2 0 0,1 12,17M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1Z"
                            Width="20" Height="20"
                            Margin="0,0,12,0"
                            Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                  <TextBlock Grid.Column="1"
                             Text="隐私政策"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                  <PathIcon Grid.Column="2"
                            Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z"
                            Width="20" Height="20"
                            Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                </Grid>
              </Border>
            </StackPanel>
          </Border>
        </StackPanel>

      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>