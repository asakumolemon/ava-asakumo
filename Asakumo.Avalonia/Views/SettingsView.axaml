<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Asakumo.Avalonia.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:Class="Asakumo.Avalonia.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             Background="{DynamicResource AppBackgroundBrush}">

  <Grid RowDefinitions="Auto, *">
    <!-- Toast Notification -->
    <Border Grid.Row="0" Grid.RowSpan="2"
            Classes="toast-notification"
            IsVisible="{Binding ShowToast}">
      <TextBlock Text="{Binding ToastMessage}"
                 Foreground="{DynamicResource AppTextPrimaryBrush}"
                 FontSize="14"/>
    </Border>

    <!-- Clear All Data Confirmation Dialog -->
    <Border Grid.Row="0" Grid.RowSpan="2"
            Classes="dialog-overlay"
            IsVisible="{Binding ShowClearDataConfirmDialog}">
      <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <Border Classes="dialog-card">
          <StackPanel Spacing="16">
            <!-- Icon -->
            <PathIcon Data="{StaticResource IconWarning}"
                        Width="48" Height="48"
                        HorizontalAlignment="Center"
                        Foreground="{DynamicResource WarningBrush}"/>

            <!-- Title -->
            <TextBlock Text="清除所有数据？"
                       FontSize="18"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource AppTextPrimaryBrush}"/>

            <!-- Message -->
            <TextBlock Text="此操作将永久删除所有会话、消息和设置。此操作无法撤销，应用将自动重启。"
                       FontSize="14"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="12">
              <Button Content="取消"
                      Command="{Binding CancelClearAllDataCommand}"
                      Classes="btn-outlined"
                      Width="100"/>
              <Button Content="确认清除"
                      Command="{Binding ConfirmClearAllDataCommand}"
                      Classes="btn-danger"
                      Width="100"/>
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <!-- Header - MD3 Top App Bar -->
    <Border Grid.Row="0"
            Classes="top-app-bar">
      <Grid ColumnDefinitions="Auto, *, Auto">
        <Button Grid.Column="0"
                Command="{Binding GoBackCommand}"
                Classes="icon"
                VerticalAlignment="Center"
                ToolTip.Tip="返回">
          <PathIcon Data="{StaticResource IconBack}"
                    Width="24" Height="24"
                    Foreground="{DynamicResource AppTextSecondaryBrush}"/>
        </Button>

        <TextBlock Grid.Column="1"
                   Text="设置"
                   FontSize="20"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource AppTextPrimaryBrush}"/>

        <Border Grid.Column="2" Width="40"/>
      </Grid>
    </Border>

    <!-- Content -->
    <ScrollViewer Grid.Row="1"
                  Background="{DynamicResource AppBackgroundBrush}">
      <StackPanel>

        <!-- AI Configuration Section -->
        <StackPanel>
          <TextBlock Text="AI 配置"
                     Classes="settings-section-title"
                     Foreground="{DynamicResource AppTextTertiaryBrush}"/>
          <Border Classes="settings-card">
            <StackPanel>
              <!-- Provider Configuration -->
              <Button Command="{Binding NavigateToProviderConfigCommand}"
                      Background="Transparent"
                      BorderThickness="0"
                      Padding="0"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <Border Classes="settings-item">
                  <Grid ColumnDefinitions="56, *, 24" Margin="16,0">
                    <!-- Icon -->
                    <Border Grid.Column="0"
                            Classes="settings-icon-bg"
                            Background="{DynamicResource PrimaryBrush}">
                      <PathIcon Data="{StaticResource IconSettings}"
                                Classes="settings-icon"
                                Foreground="{DynamicResource AppBackgroundBrush}"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                      <TextBlock Text="供应商配置"
                                 Classes="settings-title"
                                 Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                      <TextBlock Text="{Binding AiConfigurationStatus}"
                                 Classes="settings-subtitle"
                                 Foreground="{DynamicResource AppTextTertiaryBrush}"/>
                    </StackPanel>

                    <PathIcon Grid.Column="2"
                              Data="{StaticResource IconChevronRight}"
                              Width="20" Height="20"
                              Foreground="{DynamicResource AppTextTertiaryBrush}"/>
                  </Grid>
                </Border>
              </Button>

              <Separator Classes="settings-divider"/>

              <!-- Default Model Configuration -->
              <Button Command="{Binding NavigateToDefaultModelConfigCommand}"
                      Background="Transparent"
                      BorderThickness="0"
                      Padding="0"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <Border Classes="settings-item">
                  <Grid ColumnDefinitions="56, *, 24" Margin="16,0">
                    <!-- Icon -->
                    <Border Grid.Column="0"
                            Classes="settings-icon-bg"
                            Background="{DynamicResource AppSurfaceBrush}">
                      <PathIcon Data="{StaticResource IconModel}"
                                Classes="settings-icon"
                                Foreground="{DynamicResource AstralVioletBrush}"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                      <TextBlock Text="默认模型"
                                 Classes="settings-title"
                                 Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                      <TextBlock Text="{Binding DefaultModelStatus}"
                                 Classes="settings-subtitle"
                                 Foreground="{DynamicResource AppTextTertiaryBrush}"/>
                    </StackPanel>

                    <PathIcon Grid.Column="2"
                              Data="{StaticResource IconChevronRight}"
                              Width="20" Height="20"
                              Foreground="{DynamicResource AppTextTertiaryBrush}"/>
                  </Grid>
                </Border>
              </Button>
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- Appearance Section -->
        <StackPanel>
          <TextBlock Text="外观"
                     Classes="settings-section-title"
                     Foreground="{DynamicResource AppTextTertiaryBrush}"/>
          <Border Classes="settings-card">
            <StackPanel>
              <!-- Dark Mode -->
              <Border Classes="settings-item">
                <Grid ColumnDefinitions="56, *, 50" Margin="16,0">
                  <PathIcon Grid.Column="0"
                            Data="{StaticResource IconDarkMode}"
                            Width="24" Height="24"
                            Foreground="{DynamicResource FrostCyanBrush}"/>
                  <TextBlock Grid.Column="1"
                             Text="深色模式"
                             VerticalAlignment="Center"
                             Classes="settings-title"
                             Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                  <ToggleSwitch Grid.Column="2"
                                IsChecked="{Binding IsDarkMode}"/>
                </Grid>
              </Border>

              <Separator Classes="settings-divider"/>

              <!-- Language -->
              <Button Command="{Binding OpenLanguageSettingsCommand}"
                      Background="Transparent"
                      BorderThickness="0"
                      Padding="0"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <Border Classes="settings-item">
                  <Grid ColumnDefinitions="56, *, 24" Margin="16,0">
                    <PathIcon Grid.Column="0"
                              Data="{StaticResource IconLanguage}"
                              Width="24" Height="24"
                              Foreground="{DynamicResource SilverMistBrush}"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                      <TextBlock Text="语言"
                                 Classes="settings-title"
                                 Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                      <TextBlock Text="{Binding SelectedLanguage}"
                                 Classes="settings-subtitle"
                                 Foreground="{DynamicResource AppTextTertiaryBrush}"/>
                    </StackPanel>
                    <PathIcon Grid.Column="2"
                              Data="{StaticResource IconChevronRight}"
                              Width="20" Height="20"
                              Foreground="{DynamicResource AppTextTertiaryBrush}"/>
                  </Grid>
                </Border>
              </Button>
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- Data Section -->
        <StackPanel>
          <TextBlock Text="数据"
                     Classes="settings-section-title"
                     Foreground="{DynamicResource AppTextTertiaryBrush}"/>
          <Border Classes="settings-card">
            <StackPanel>
              <!-- Backup -->
              <Button Command="{Binding BackupCommand}"
                      Background="Transparent"
                      BorderThickness="0"
                      Padding="0"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <Border Classes="settings-item">
                  <Grid ColumnDefinitions="56, *, 24" Margin="16,0">
                    <PathIcon Grid.Column="0"
                              Data="{StaticResource IconBackup}"
                              Width="24" Height="24"
                              Foreground="{DynamicResource SuccessBrush}"/>
                    <TextBlock Grid.Column="1"
                               Text="备份与恢复"
                               VerticalAlignment="Center"
                               Classes="settings-title"
                               Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                    <PathIcon Grid.Column="2"
                              Data="{StaticResource IconChevronRight}"
                              Width="20" Height="20"
                              Foreground="{DynamicResource AppTextTertiaryBrush}"/>
                  </Grid>
                </Border>
              </Button>

              <Separator Classes="settings-divider"/>

              <!-- Clear Data -->
              <Button Command="{Binding ClearConversationsCommand}"
                      Background="Transparent"
                      BorderThickness="0"
                      Padding="0"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <Border Classes="settings-item">
                  <Grid ColumnDefinitions="56, *, 24" Margin="16,0">
                    <PathIcon Grid.Column="0"
                              Data="{StaticResource IconDelete}"
                              Width="24" Height="24"
                              Foreground="{DynamicResource ErrorBrush}"/>
                    <TextBlock Grid.Column="1"
                               Text="清除所有会话"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource ErrorBrush}"/>
                    <PathIcon Grid.Column="2"
                              Data="{StaticResource IconChevronRight}"
                              Width="20" Height="20"
                              Foreground="{DynamicResource AppTextTertiaryBrush}"/>
                  </Grid>
                </Border>
              </Button>

              <Separator Classes="settings-divider"/>

              <!-- Clear All Data -->
              <Button Command="{Binding OpenClearDataDialogCommand}"
                      Background="Transparent"
                      BorderThickness="0"
                      Padding="0"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <Border Classes="settings-item">
                  <Grid ColumnDefinitions="56, *, 24" Margin="16,0">
                    <PathIcon Grid.Column="0"
                              Data="{StaticResource IconClearAll}"
                              Width="24" Height="24"
                              Foreground="{DynamicResource ErrorBrush}"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                      <TextBlock Text="清除所有数据"
                                 Foreground="{DynamicResource ErrorBrush}"/>
                      <TextBlock Text="包括会话和设置，应用将重启"
                                 Classes="settings-subtitle"
                                 Foreground="{DynamicResource AppTextTertiaryBrush}"/>
                    </StackPanel>
                    <PathIcon Grid.Column="2"
                              Data="{StaticResource IconWarning}"
                              Width="20" Height="20"
                              Foreground="{DynamicResource WarningBrush}"/>
                  </Grid>
                </Border>
              </Button>
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- About Section -->
        <StackPanel>
          <TextBlock Text="关于"
                     Classes="settings-section-title"
                     Foreground="{DynamicResource AppTextTertiaryBrush}"/>
          <Border Classes="settings-card">
            <StackPanel>
              <!-- Version -->
              <Border Classes="settings-item">
                <Grid ColumnDefinitions="56, *" Margin="16,0">
                  <PathIcon Grid.Column="0"
                            Data="{StaticResource IconInfo}"
                            Width="24" Height="24"
                            Foreground="{DynamicResource FrostCyanBrush}"/>
                  <TextBlock Grid.Column="1"
                             Text="{Binding AppVersion}"
                             VerticalAlignment="Center"
                             Classes="settings-title"
                             Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                </Grid>
              </Border>

              <Separator Classes="settings-divider"/>

              <!-- Privacy Policy -->
              <Button Command="{Binding OpenPrivacyPolicyCommand}"
                      Background="Transparent"
                      BorderThickness="0"
                      Padding="0"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <Border Classes="settings-item">
                  <Grid ColumnDefinitions="56, *, 24" Margin="16,0">
                    <PathIcon Grid.Column="0"
                              Data="{StaticResource IconShield}"
                              Width="24" Height="24"
                              Foreground="{DynamicResource AstralVioletBrush}"/>
                    <TextBlock Grid.Column="1"
                               Text="隐私政策"
                               VerticalAlignment="Center"
                               Classes="settings-title"
                               Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                    <PathIcon Grid.Column="2"
                              Data="{StaticResource IconChevronRight}"
                              Width="20" Height="20"
                              Foreground="{DynamicResource AppTextTertiaryBrush}"/>
                  </Grid>
                </Border>
              </Button>
            </StackPanel>
          </Border>
        </StackPanel>

      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>