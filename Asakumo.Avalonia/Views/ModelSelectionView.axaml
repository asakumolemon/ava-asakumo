<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Asakumo.Avalonia.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:Class="Asakumo.Avalonia.Views.ModelSelectionView"
             x:DataType="vm:ModelSelectionViewModel">

  <Grid RowDefinitions="Auto, *, Auto" Background="#090C14">
    <!-- Header - Rani 风格 -->
    <Border Grid.Row="0" Padding="16,12" 
            Background="#0D1220"
            BorderBrush="#1E2A4A"
            BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto, *, Auto">
        <Button Grid.Column="0" Command="{Binding GoBackCommand}"
                Classes="icon" ToolTip.Tip="返回">
          <PathIcon Data="M20,11H7.83L13.42,5.41L12,4L4,12L12,20L13.41,18.59L7.83,13H20V11Z"
                    Width="20" Height="20"
                    Foreground="#C8D2EA"/>
        </Button>
        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"
                    VerticalAlignment="Center" Spacing="8">
          <TextBlock Text="{Binding ProviderIcon}" FontSize="18"/>
          <TextBlock Text="{Binding ProviderName}" FontSize="18" FontWeight="SemiBold"
                     Foreground="#F3F6FF"/>
        </StackPanel>
        <TextBlock Grid.Column="2" Text="{Binding SelectedCount, StringFormat='已选 {0}'}"
                   VerticalAlignment="Center" FontSize="14"
                   Foreground="#8EDBFF"/>
      </Grid>
    </Border>

    <!-- Model List -->
    <ScrollViewer Grid.Row="1">
      <StackPanel Spacing="12" Margin="16">
        <!-- Instructions -->
        <TextBlock Text="点击 + 添加模型，点击 ✓ 移除模型："
                   Foreground="#7E8AAC"
                   TextWrapping="Wrap" Margin="0,8,0,16"/>

        <!-- Model Cards -->
        <ItemsControl ItemsSource="{Binding Models}">
          <ItemsControl.Styles>
            <Style Selector="Border.model-card">
              <Setter Property="Background" Value="#11182B"/>
              <Setter Property="BorderThickness" Value="2"/>
              <Setter Property="BorderBrush" Value="#2A3654"/>
              <Setter Property="CornerRadius" Value="16"/>
              <Setter Property="Padding" Value="12"/>
              <Setter Property="Margin" Value="0,0,0,8"/>
            </Style>
            <Style Selector="Border.model-card.selected">
              <Setter Property="BorderBrush" Value="#8FA8FF"/>
              <Setter Property="Background" Value="#1A2B4D"/>
            </Style>
          </ItemsControl.Styles>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="vm:ModelSelectionItem">
              <Border Classes="model-card">
                <Grid ColumnDefinitions="*, Auto">
                  <!-- Info -->
                  <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Model.Name}" FontSize="16" FontWeight="Medium"
                               Foreground="#F3F6FF"/>
                    <TextBlock Text="{Binding Model.Description}" FontSize="12"
                               Foreground="#7E8AAC"
                               TextWrapping="Wrap" MaxLines="2"/>
                    <!-- Capabilities -->
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                      <Border Background="#1A8EDBFF" CornerRadius="4" Padding="6,2"
                              IsVisible="{Binding Model.SupportsVision}">
                        <TextBlock Text="视觉" FontSize="10" Foreground="#8EDBFF"/>
                      </Border>
                      <Border Background="#1AA792E8" CornerRadius="4" Padding="6,2"
                              IsVisible="{Binding Model.SupportsFunctionCalling}">
                        <TextBlock Text="工具调用" FontSize="10" Foreground="#A792E8"/>
                      </Border>
                      <Border Background="#1A8FA8FF" CornerRadius="4" Padding="6,2">
                        <TextBlock Text="{Binding Model.MaxTokens, StringFormat='{}{0:N0} tokens'}"
                                   FontSize="10" Foreground="#8FA8FF"/>
                      </Border>
                    </StackPanel>
                  </StackPanel>

                  <!-- Add/Remove Button -->
                  <Button Grid.Column="1" Width="36" Height="36" CornerRadius="18"
                          Background="#8FA8FF"
                          Command="{Binding $parent[ItemsControl].((vm:ModelSelectionViewModel)DataContext).ToggleModelCommand}"
                          CommandParameter="{Binding}"
                          VerticalAlignment="Center"
                          Margin="8,0,0,0">
                    <Panel>
                      <!-- Plus Icon (Not Selected) -->
                      <PathIcon Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"
                                Width="20" Height="20"
                                Foreground="#08101F"
                                IsVisible="{Binding !IsSelected}"/>
                      <!-- Check Icon (Selected) -->
                      <PathIcon Data="M21,7L9,19L3.5,13.5L4.91,12.09L9,16.17L19.59,5.59L21,7Z"
                                Width="20" Height="20"
                                Foreground="#08101F"
                                IsVisible="{Binding IsSelected}"/>
                    </Panel>
                  </Button>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Error Message -->
        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="#F28AA8" FontSize="14"
                   IsVisible="{Binding HasError}"
                   Margin="0,8"/>

        <!-- Success Message -->
        <TextBlock Text="{Binding SuccessMessage}"
                   Foreground="#6FD7B8" FontSize="14"
                   IsVisible="{Binding HasSuccess}"
                   Margin="0,8"/>
      </StackPanel>
    </ScrollViewer>

    <!-- Footer - Rani 风格 -->
    <Border Grid.Row="2" Padding="16" 
            Background="#0D1220"
            BorderBrush="#1E2A4A"
            BorderThickness="0,1,0,0">
      <Button Command="{Binding SaveCommand}"
              Classes="primary"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"
              IsEnabled="{Binding CanSave}">
        <TextBlock Text="{Binding SelectedCount, StringFormat='保存 ({0})'}"
                   FontWeight="SemiBold" FontSize="16"
                   Foreground="#08101F"/>
      </Button>
    </Border>
  </Grid>
</UserControl>
