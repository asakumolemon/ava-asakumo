<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Asakumo.Avalonia.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:Class="Asakumo.Avalonia.Views.ProviderManagementView"
             x:DataType="vm:ProviderManagementViewModel"
             Background="{DynamicResource AppBackgroundBrush}">

  <Grid RowDefinitions="Auto, *, Auto">
    <!-- Header -->
    <Border Grid.Row="0"
            Background="{DynamicResource AppBackgroundBrush}"
            Height="64"
            Padding="16,0">
      <Grid ColumnDefinitions="Auto, *, Auto">
        <Button Grid.Column="0"
                Command="{Binding GoBackCommand}"
                Classes="icon"
                VerticalAlignment="Center"
                ToolTip.Tip="返回">
          <PathIcon Data="M20,11H7.83L13.42,5.41L12,4L4,12L12,20L13.41,18.59L7.83,13H20V11Z"
                    Width="24" Height="24"/>
        </Button>

        <TextBlock Grid.Column="1"
                   Text="供应商管理"
                   FontSize="20"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Foreground="{DynamicResource AppTextPrimaryBrush}"/>

        <Border Grid.Column="2" Width="40"/>
      </Grid>
    </Border>

    <!-- Content -->
    <ScrollViewer Grid.Row="1">
      <StackPanel Spacing="16" Margin="16">
        <!-- Test Result Banner -->
        <Border Background="{DynamicResource SuccessBrush}"
                CornerRadius="12"
                Padding="16,12"
                IsVisible="{Binding TestSuccess, Converter={x:Static ObjectConverters.IsNotNull}}">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <PathIcon Data="M9,16.17L4.83,12L3.41,13.41L9,19L21,7L19.59,5.59L9,16.17Z"
                      Width="20" Height="20"
                      Foreground="White"
                      IsVisible="{Binding TestSuccess}"/>
            <PathIcon Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                      Width="20" Height="20"
                      Foreground="White"
                      IsVisible="{Binding !TestSuccess}"/>
            <TextBlock Text="{Binding TestResultMessage}"
                       Foreground="White"
                       FontWeight="Medium"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Providers List -->
        <ItemsControl ItemsSource="{Binding Providers}">
          <ItemsControl.Styles>
            <!-- Provider Item Card Style -->
            <Style Selector="Border.provider-card">
              <Setter Property="Background" Value="{DynamicResource AppCardBrush}"/>
              <Setter Property="CornerRadius" Value="12"/>
              <Setter Property="Padding" Value="16"/>
            </Style>
            <Style Selector="Border.provider-card:pointerover">
              <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
            </Style>
          </ItemsControl.Styles>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:ProviderItemViewModel">
              <Border Classes="provider-card" Margin="0,0,0,8">
                <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="Auto, *, Auto">
                  <!-- Row 1: Icon, Name, Toggle -->
                  <Border Grid.Row="0" Grid.Column="0"
                          Width="40" Height="40"
                          CornerRadius="20"
                          Background="{DynamicResource AppSurfaceBrush}"
                          VerticalAlignment="Center">
                    <PathIcon Data="{Binding Icon}"
                              Width="24" Height="24"
                              Foreground="{DynamicResource PrimaryBrush}"/>
                  </Border>

                  <StackPanel Grid.Row="0" Grid.Column="1"
                              Margin="12,0"
                              VerticalAlignment="Center">
                    <TextBlock Text="{Binding Name}"
                               FontSize="16"
                               FontWeight="Medium"
                               Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                    <TextBlock Text="{Binding EnabledModelCount, StringFormat='{}{0} 个模型'}"
                               FontSize="12"
                               Foreground="{DynamicResource AppTextSecondaryBrush}"
                               IsVisible="{Binding IsEnabled}"/>
                  </StackPanel>

                  <ToggleSwitch Grid.Row="0" Grid.Column="2"
                                IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                Command="{Binding $parent[ItemsControl].((vm:ProviderManagementViewModel)DataContext).ToggleProviderCommand}"
                                CommandParameter="{Binding}"
                                VerticalAlignment="Center"/>

                  <!-- Row 2: Status Badge -->
                  <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                              Orientation="Horizontal"
                              Spacing="8"
                              Margin="0,8,0,0">
                    <Border Background="{DynamicResource SuccessBrush}"
                            CornerRadius="4"
                            Padding="6,2"
                            IsVisible="{Binding IsValid}">
                      <TextBlock Text="已配置"
                                 FontSize="11"
                                 Foreground="White"/>
                    </Border>
                    <Border Background="{DynamicResource ErrorBrush}"
                            CornerRadius="4"
                            Padding="6,2"
                            IsVisible="{Binding !IsValid}">
                      <TextBlock Text="未配置"
                                 FontSize="11"
                                 Foreground="White"/>
                    </Border>
                    <Border Background="{DynamicResource AppSurfaceBrush}"
                            CornerRadius="4"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            Padding="6,2"
                            IsVisible="{Binding !IsEnabled}">
                      <TextBlock Text="已禁用"
                                 FontSize="11"
                                 Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                    </Border>
                  </StackPanel>

                  <!-- Row 3: Action Buttons -->
                  <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                              Orientation="Horizontal"
                              Spacing="8"
                              Margin="0,12,0,0">
                    <Button Classes="secondary"
                            Command="{Binding $parent[ItemsControl].((vm:ProviderManagementViewModel)DataContext).ConfigureProviderCommand}"
                            CommandParameter="{Binding}"
                            IsVisible="{Binding CanConfigure}">
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <PathIcon Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"
                                  Width="16" Height="16"/>
                        <TextBlock Text="配置"/>
                      </StackPanel>
                    </Button>

                    <Button Classes="secondary"
                            Command="{Binding $parent[ItemsControl].((vm:ProviderManagementViewModel)DataContext).TestProviderCommand}"
                            CommandParameter="{Binding}"
                            IsVisible="{Binding CanTest}"
                            IsEnabled="{Binding !$parent[ItemsControl].((vm:ProviderManagementViewModel)DataContext).IsTesting}">
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <PathIcon Data="M9,16.17L4.83,12L3.41,13.41L9,19L21,7L19.59,5.59L9,16.17Z"
                                  Width="16" Height="16"/>
                        <TextBlock Text="测试连接"/>
                      </StackPanel>
                    </Button>

                    <Button Classes="icon"
                            Command="{Binding $parent[ItemsControl].((vm:ProviderManagementViewModel)DataContext).RefreshModelsCommand}"
                            CommandParameter="{Binding}"
                            IsVisible="{Binding IsConfigured}">
                      <PathIcon Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"
                                Width="18" Height="18"/>
                    </Button>
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Add Custom Provider Button -->
        <Button Classes="primary"
                HorizontalAlignment="Stretch"
                Height="48"
                CornerRadius="24">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <PathIcon Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"
                      Width="20" Height="20"
                      Foreground="White"/>
            <TextBlock Text="添加自定义供应商"
                       FontWeight="SemiBold"
                       Foreground="White"/>
          </StackPanel>
        </Button>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
