<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Asakumo.Avalonia.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:Class="Asakumo.Avalonia.Views.ProviderManagementView"
             x:DataType="vm:ProviderManagementViewModel"
             Background="{DynamicResource AppBackgroundBrush}">

  <Grid RowDefinitions="Auto, *, Auto">
    <!-- Header -->
    <Border Grid.Row="0"
            Background="{DynamicResource AppBackgroundBrush}"
            Height="64"
            Padding="16,0">
      <Grid ColumnDefinitions="Auto, *, Auto">
        <Button Grid.Column="0"
                Command="{Binding GoBackCommand}"
                Classes="icon"
                VerticalAlignment="Center"
                ToolTip.Tip="返回">
          <PathIcon Data="M20,11H7.83L13.42,5.41L12,4L4,12L12,20L13.41,18.59L7.83,13H20V11Z"
                    Width="24" Height="24"/>
        </Button>

        <TextBlock Grid.Column="1"
                   Text="供应商管理"
                   FontSize="20"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Foreground="{DynamicResource AppTextPrimaryBrush}"/>

        <Border Grid.Column="2" Width="40"/>
      </Grid>
    </Border>

    <!-- Content -->
    <ScrollViewer Grid.Row="1">
      <StackPanel Spacing="16" Margin="16">
        <!-- Test Result Banner -->
        <Border Background="{DynamicResource SuccessBrush}"
                CornerRadius="12"
                Padding="16,12"
                IsVisible="{Binding TestSuccess, Converter={x:Static ObjectConverters.IsNotNull}}">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <PathIcon Data="M9,16.17L4.83,12L3.41,13.41L9,19L21,7L19.59,5.59L9,16.17Z"
                      Width="20" Height="20"
                      Foreground="White"
                      IsVisible="{Binding TestSuccess}"/>
            <PathIcon Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                      Width="20" Height="20"
                      Foreground="White"
                      IsVisible="{Binding !TestSuccess}"/>
            <TextBlock Text="{Binding TestResultMessage}"
                       Foreground="White"
                       FontWeight="Medium"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Providers List -->
        <ItemsControl ItemsSource="{Binding Providers}">
          <ItemsControl.Styles>
            <!-- Provider Item Card Style -->
            <Style Selector="Border.provider-card">
              <Setter Property="Background" Value="{DynamicResource AppCardBrush}"/>
              <Setter Property="CornerRadius" Value="12"/>
              <Setter Property="Padding" Value="16"/>
            </Style>
            <Style Selector="Border.provider-card:pointerover">
              <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
            </Style>
          </ItemsControl.Styles>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:ProviderItemViewModel">
              <Border Classes="provider-card" Margin="0,0,0,8">
                <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="Auto, *, Auto">
                  <!-- Row 1: Icon, Name, Toggle -->
                  <Border Grid.Row="0" Grid.Column="0"
                          Width="40" Height="40"
                          CornerRadius="20"
                          Background="{DynamicResource AppSurfaceBrush}"
                          VerticalAlignment="Center">
                    <PathIcon Data="{Binding Icon}"
                              Width="24" Height="24"
                              Foreground="{DynamicResource PrimaryBrush}"/>
                  </Border>

                  <StackPanel Grid.Row="0" Grid.Column="1"
                              Margin="12,0"
                              VerticalAlignment="Center">
                    <TextBlock Text="{Binding Name}"
                               FontSize="16"
                               FontWeight="Medium"
                               Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                    <TextBlock Text="{Binding EnabledModelCount, StringFormat='{}{0} 个模型'}"
                               FontSize="12"
                               Foreground="{DynamicResource AppTextSecondaryBrush}"
                               IsVisible="{Binding IsConfigured}"/>
                  </StackPanel>

                  <!-- Row 2: Status Badge -->
                  <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                              Orientation="Horizontal"
                              Spacing="8"
                              Margin="0,8,0,0">
                    <Border Background="{DynamicResource SuccessBrush}"
                            CornerRadius="4"
                            Padding="6,2"
                            IsVisible="{Binding IsValid}">
                      <TextBlock Text="已配置"
                                 FontSize="11"
                                 Foreground="White"/>
                    </Border>
                    <Border Background="{DynamicResource ErrorBrush}"
                            CornerRadius="4"
                            Padding="6,2"
                            IsVisible="{Binding !IsValid}">
                      <TextBlock Text="未配置"
                                 FontSize="11"
                                 Foreground="White"/>
                    </Border>
                  </StackPanel>

                  <!-- Row 3: Action Buttons -->
                  <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                              Orientation="Horizontal"
                              Spacing="8"
                              Margin="0,12,0,0">
                    <Button Classes="secondary"
                            Command="{Binding $parent[ItemsControl].((vm:ProviderManagementViewModel)DataContext).ConfigureProviderCommand}"
                            CommandParameter="{Binding}">
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <PathIcon Data="M19.14,12.94C19.18,12.64 19.2,12.33 19.2,12C19.2,11.68 19.18,11.36 19.13,11.06L21.16,9.48C21.34,9.34 21.39,9.07 21.28,8.87L19.36,5.55C19.24,5.33 18.99,5.26 18.77,5.33L16.38,6.29C15.88,5.91 15.35,5.59 14.76,5.35L14.4,2.81C14.36,2.57 14.16,2.4 13.92,2.4H10.08C9.84,2.4 9.65,2.57 9.61,2.81L9.25,5.35C8.66,5.59 8.12,5.92 7.63,6.29L5.24,5.33C5.02,5.25 4.77,5.33 4.65,5.55L2.74,8.87C2.62,9.08 2.66,9.34 2.86,9.48L4.89,11.06C4.84,11.36 4.8,11.69 4.8,12C4.8,12.31 4.82,12.64 4.87,12.94L2.84,14.52C2.66,14.66 2.61,14.93 2.72,15.13L4.64,18.45C4.76,18.68 5,18.74 5.23,18.67L7.62,17.71C8.12,18.09 8.65,18.41 9.24,18.65L9.6,21.19C9.65,21.43 9.84,21.6 10.08,21.6H13.92C14.16,21.6 14.36,21.43 14.39,21.19L14.75,18.65C15.34,18.41 15.88,18.09 16.37,17.71L18.76,18.67C18.98,18.75 19.23,18.67 19.35,18.45L21.27,15.13C21.39,14.91 21.34,14.66 21.15,14.52L19.14,12.94M12,15.6A3.6,3.6 0 0,1 8.4,12A3.6,3.6 0 0,1 12,8.4A3.6,3.6 0 0,1 15.6,12A3.6,3.6 0 0,1 12,15.6Z"
                                  Width="16" Height="16"/>
                        <TextBlock Text="配置"/>
                      </StackPanel>
                    </Button>

                    <Button Classes="secondary"
                            Command="{Binding $parent[ItemsControl].((vm:ProviderManagementViewModel)DataContext).TestProviderCommand}"
                            CommandParameter="{Binding}"
                            IsVisible="{Binding CanTest}"
                            IsEnabled="{Binding !$parent[ItemsControl].((vm:ProviderManagementViewModel)DataContext).IsTesting}">
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <PathIcon Data="M9,16.17L4.83,12L3.41,13.41L9,19L21,7L19.59,5.59L9,16.17Z"
                                  Width="16" Height="16"/>
                        <TextBlock Text="测试连接"/>
                      </StackPanel>
                    </Button>

                    <Button Classes="icon"
                            Command="{Binding $parent[ItemsControl].((vm:ProviderManagementViewModel)DataContext).RefreshModelsCommand}"
                            CommandParameter="{Binding}"
                            IsVisible="{Binding IsConfigured}">
                      <PathIcon Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"
                                Width="18" Height="18"/>
                    </Button>
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Add Custom Provider Button -->
        <Button Classes="primary"
                HorizontalAlignment="Stretch"
                Height="48"
                CornerRadius="24">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <PathIcon Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"
                      Width="20" Height="20"
                      Foreground="White"/>
            <TextBlock Text="添加自定义供应商"
                       FontWeight="SemiBold"
                       Foreground="White"/>
          </StackPanel>
        </Button>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
