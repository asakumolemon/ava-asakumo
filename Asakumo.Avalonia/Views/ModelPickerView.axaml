<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Asakumo.Avalonia.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="600"
             x:Class="Asakumo.Avalonia.Views.ModelPickerView"
             x:DataType="vm:ModelPickerViewModel"
             Background="Transparent">

  <!-- Bottom Sheet Style Model Picker -->
  <Border Background="{DynamicResource AppBackgroundBrush}"
          CornerRadius="16,16,0,0"
          BoxShadow="0 -4 20 0 #40000000">
    <Grid RowDefinitions="Auto, Auto, Auto, *" MaxHeight="500">

      <!-- Handle Bar -->
      <Border Grid.Row="0"
              Height="24"
              Background="Transparent"
              PointerPressed="OnDragPointerPressed"
              PointerMoved="OnDragPointerMoved"
              PointerReleased="OnDragPointerReleased">
        <Border Width="40" Height="4"
                Background="{DynamicResource AppTextSecondaryBrush}"
                Opacity="0.4"
                CornerRadius="2"
                VerticalAlignment="Center"/>
      </Border>

      <!-- Header -->
      <Grid Grid.Row="1"
            ColumnDefinitions="*, Auto"
            Margin="16,0,16,12">
        <StackPanel Grid.Column="0" Spacing="2">
          <TextBlock Text="选择模型"
                     FontSize="18"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource AppTextPrimaryBrush}"/>
          <TextBlock Text="切换当前会话使用的 AI 模型"
                     FontSize="12"
                     Opacity="0.6"
                     Foreground="{DynamicResource AppTextSecondaryBrush}"/>
        </StackPanel>

        <Button Grid.Column="1"
                Command="{Binding CloseCommand}"
                Classes="icon"
                VerticalAlignment="Top"
                ToolTip.Tip="关闭">
          <PathIcon Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                    Width="20" Height="20"/>
        </Button>
      </Grid>

      <!-- Search Box -->
      <Border Grid.Row="2"
              Background="{DynamicResource AppSurfaceBrush}"
              CornerRadius="12"
              Padding="12,8"
              Margin="16,0,16,12">
        <Grid ColumnDefinitions="Auto, *, Auto">
          <PathIcon Grid.Column="0"
                    Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"
                    Width="20" Height="20"
                    Foreground="{DynamicResource AppTextSecondaryBrush}"/>

          <TextBox Grid.Column="1"
                   Text="{Binding SearchQuery}"
                   Watermark="搜索模型..."
                   Background="Transparent"
                   BorderThickness="0"
                   VerticalAlignment="Center"
                   Margin="8,0"/>

          <Button Grid.Column="2"
                  Command="{Binding ClearSearchCommand}"
                  Classes="icon"
                  IsVisible="{Binding SearchQuery, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                  VerticalAlignment="Center">
            <PathIcon Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                      Width="16" Height="16"/>
          </Button>
        </Grid>
      </Border>

      <!-- Content -->
      <ScrollViewer Grid.Row="3"
                    Margin="16,0,16,16"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12">

          <!-- Loading Indicator -->
          <StackPanel IsVisible="{Binding IsLoading}"
                      HorizontalAlignment="Center"
                      Spacing="8"
                      Margin="0,40">
            <ProgressBar IsIndeterminate="True"
                         Width="32" Height="32"/>
            <TextBlock Text="加载中..."
                       FontSize="13"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"/>
          </StackPanel>

          <!-- Recent Models -->
          <StackPanel IsVisible="{Binding HasRecentModels}"
                      Spacing="8">
            <TextBlock Text="最近使用"
                       FontSize="12"
                       FontWeight="Medium"
                       Opacity="0.7"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                       Margin="4,0,0,4"/>

            <ItemsControl ItemsSource="{Binding RecentModels}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ModelListItemViewModel">
                  <Button Command="{Binding $parent[ItemsControl].((vm:ModelPickerViewModel)DataContext).SelectModelCommand}"
                          CommandParameter="{Binding}"
                          Background="{DynamicResource AppSurfaceBrush}"
                          BorderThickness="0"
                          Padding="12,10"
                          Margin="0,0,0,6"
                          CornerRadius="10"
                          HorizontalAlignment="Stretch"
                          IsVisible="{Binding IsVisible}">
                    <Grid ColumnDefinitions="Auto, *, Auto">
                      <!-- Provider Icon -->
                      <Border Grid.Column="0"
                              Width="32" Height="32"
                              CornerRadius="16"
                              Background="{DynamicResource PrimaryBrush}">
                        <PathIcon Data="{Binding ProviderIcon}"
                                  Width="16" Height="16"
                                  Foreground="White"/>
                      </Border>

                      <!-- Model Info -->
                      <StackPanel Grid.Column="1"
                                  Margin="12,0"
                                  VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                        <TextBlock Text="{Binding ProviderName}"
                                   FontSize="11"
                                   Opacity="0.6"
                                   Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                      </StackPanel>

                      <!-- Current Indicator -->
                      <PathIcon Grid.Column="2"
                                Data="M9,16.17L4.83,12L3.41,13.41L9,19L21,7L19.59,5.59L9,16.17Z"
                                Width="18" Height="18"
                                Foreground="{DynamicResource SuccessBrush}"
                                IsVisible="{Binding IsCurrent}"/>
                    </Grid>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

          <!-- Provider Groups -->
          <ItemsControl ItemsSource="{Binding ProviderGroups}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:ProviderGroupViewModel">
                <StackPanel Spacing="6"
                            IsVisible="{Binding IsVisible}">

                  <!-- Provider Header -->
                  <Button Command="{Binding ToggleExpandCommand}"
                          Background="Transparent"
                          BorderThickness="0"
                          Padding="4,8"
                          HorizontalAlignment="Stretch">
                    <Grid ColumnDefinitions="Auto, *, Auto">
                      <Border Grid.Column="0"
                              Width="24" Height="24"
                              CornerRadius="12"
                              Background="{DynamicResource AppSurfaceBrush}">
                        <PathIcon Data="{Binding ProviderIcon}"
                                  Width="14" Height="14"
                                  Foreground="{DynamicResource PrimaryBrush}"/>
                      </Border>

                      <TextBlock Grid.Column="1"
                                 Text="{Binding ProviderName}"
                                 FontSize="13"
                                 FontWeight="SemiBold"
                                 VerticalAlignment="Center"
                                 Margin="8,0"
                                 Foreground="{DynamicResource AppTextPrimaryBrush}"/>

                      <PathIcon Grid.Column="2"
                                Data="M7,10L12,15L17,10H7Z"
                                Width="16" Height="16"
                                Foreground="{DynamicResource AppTextSecondaryBrush}">
                        <PathIcon.Styles>
                          <Style Selector="PathIcon">
                            <Style.Animations>
                              <Animation Duration="0:0:0.2" Easing="CircularEaseOut">
                                <KeyFrame Cue="0%">
                                  <Setter Property="RotateTransform.Angle" Value="0"/>
                                </KeyFrame>
                                <KeyFrame Cue="100%">
                                  <Setter Property="RotateTransform.Angle" Value="180"/>
                                </KeyFrame>
                              </Animation>
                            </Style.Animations>
                          </Style>
                        </PathIcon.Styles>
                      </PathIcon>
                    </Grid>
                  </Button>

                  <!-- Models List -->
                  <ItemsControl ItemsSource="{Binding Models}"
                                IsVisible="{Binding IsExpanded}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:ModelListItemViewModel">
                        <Button Command="{Binding $parent[ItemsControl].((vm:ModelPickerViewModel)DataContext).SelectModelCommand}"
                                CommandParameter="{Binding}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="12,10"
                                Margin="28,0,0,4"
                                CornerRadius="8"
                                HorizontalAlignment="Stretch"
                                IsVisible="{Binding IsVisible}">
                          <Grid ColumnDefinitions="*, Auto">
                            <StackPanel Grid.Column="0" Spacing="2">
                              <TextBlock Text="{Binding Name}"
                                         FontSize="13"
                                         Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                              <TextBlock Text="{Binding Description}"
                                         FontSize="11"
                                         Opacity="0.6"
                                         Foreground="{DynamicResource AppTextSecondaryBrush}"
                                         TextTrimming="CharacterEllipsis"
                                         IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            </StackPanel>

                            <PathIcon Grid.Column="1"
                                      Data="M9,16.17L4.83,12L3.41,13.41L9,19L21,7L19.59,5.59L9,16.17Z"
                                      Width="16" Height="16"
                                      Foreground="{DynamicResource PrimaryBrush}"
                                      IsVisible="{Binding IsCurrent}"/>
                          </Grid>
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Empty State -->
          <StackPanel IsVisible="{Binding !HasProviderGroups}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Spacing="12"
                      Margin="0,40">
            <PathIcon Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4Z"
                      Width="48" Height="48"
                      Opacity="0.4"
                      Foreground="{DynamicResource AppTextSecondaryBrush}"/>
            <TextBlock Text="没有可用的模型"
                       FontSize="15"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"/>
            <TextBlock Text="请先配置 AI 服务提供商"
                       FontSize="12"
                       Opacity="0.7"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"/>
          </StackPanel>

          <!-- No Search Results -->
          <StackPanel IsVisible="{Binding HasNoResults}"
                      HorizontalAlignment="Center"
                      Spacing="8"
                      Margin="0,40">
            <PathIcon Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"
                      Width="40" Height="40"
                      Opacity="0.4"
                      Foreground="{DynamicResource AppTextSecondaryBrush}"/>
            <TextBlock Text="未找到匹配的模型"
                       FontSize="14"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"/>
          </StackPanel>

        </StackPanel>
      </ScrollViewer>

    </Grid>
  </Border>
</UserControl>
