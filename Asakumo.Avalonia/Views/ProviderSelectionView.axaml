<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Asakumo.Avalonia.ViewModels"
             xmlns:model="using:Asakumo.Avalonia.Models"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:Class="Asakumo.Avalonia.Views.ProviderSelectionView"
             x:DataType="vm:ProviderSelectionViewModel"
             Background="{DynamicResource AppBackgroundBrush}">

  <Grid RowDefinitions="Auto, *">
    <!-- Header -->
    <Border Grid.Row="0" 
            Background="{DynamicResource AppBackgroundBrush}"
            Padding="8,8" Height="56">
      <Grid ColumnDefinitions="Auto, *, Auto">
        <Button Grid.Column="0" 
                Command="{Binding GoBackCommand}"
                Classes="icon">
          <TextBlock Text="&#x2190;" FontSize="20"/>
        </Button>
        <TextBlock Grid.Column="1" 
                   Text="AI 服务设置" 
                   FontSize="18" 
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource AppTextPrimaryBrush}"/>
      </Grid>
    </Border>

    <!-- Content -->
    <ScrollViewer Grid.Row="1" 
                  Background="{DynamicResource AppBackgroundBrush}">
      <StackPanel Spacing="24" Margin="16">

        <TextBlock Text="选择服务提供商" 
                   FontSize="16" 
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource AppTextPrimaryBrush}"/>

        <!-- Quick Start Section -->
        <StackPanel Spacing="8" 
                    IsVisible="{Binding QuickStartProviders.Count}">
          <TextBlock Text="&#x1F31F; 快速开始" 
                     Classes="section-title"/>
          <ItemsControl ItemsSource="{Binding QuickStartProviders}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="model:AIProvider">
                <Border Background="{DynamicResource AppCardBrush}"
                        CornerRadius="12" 
                        Padding="12" 
                        Margin="0,0,0,8"
                        BorderBrush="{DynamicResource PrimaryBrush}"
                        BorderThickness="2">
                  <Button Command="{Binding $parent[ItemsControl].((vm:ProviderSelectionViewModel)DataContext).SelectProviderCommand}"
                          CommandParameter="{Binding}"
                          Background="Transparent" 
                          BorderThickness="0"
                          HorizontalAlignment="Stretch" 
                          HorizontalContentAlignment="Left"
                          Padding="0">
                    <Grid ColumnDefinitions="Auto, *, Auto">
                      <Border Width="40" Height="40" 
                              CornerRadius="20"
                              Background="{DynamicResource AppSurfaceBrush}"
                              Margin="0,0,12,0">
                        <TextBlock Text="{Binding Icon}" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"
                                   FontSize="18"/>
                      </Border>
                      <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" 
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                        <TextBlock Text="{Binding Description}" 
                                   Classes="caption"/>
                      </StackPanel>
                      <TextBlock Grid.Column="2" 
                                 Text="&#x203A;" 
                                 FontSize="18"
                                 Foreground="{DynamicResource AppTextSecondaryBrush}"
                                 VerticalAlignment="Center"/>
                    </Grid>
                  </Button>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <!-- Popular Services Section -->
        <StackPanel Spacing="8" 
                    IsVisible="{Binding PopularProviders.Count}">
          <TextBlock Text="&#x1F4E6; 热门服务" 
                     Classes="section-title"/>
          <Border Background="{DynamicResource AppCardBrush}"
                  CornerRadius="12">
            <ItemsControl ItemsSource="{Binding PopularProviders}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="model:AIProvider">
                  <Button Command="{Binding $parent[ItemsControl].((vm:ProviderSelectionViewModel)DataContext).SelectProviderCommand}"
                          CommandParameter="{Binding}"
                          Background="Transparent" 
                          BorderThickness="0"
                          HorizontalAlignment="Stretch" 
                          HorizontalContentAlignment="Left">
                    <Border Padding="12" BorderBrush="{DynamicResource AppDividerBrush}" BorderThickness="0,0,0,1">
                      <Grid ColumnDefinitions="Auto, *, Auto">
                        <Border Width="40" Height="40" 
                                CornerRadius="20"
                                Background="{DynamicResource AppSurfaceBrush}"
                                Margin="0,0,12,0">
                          <TextBlock Text="{Binding Icon}" 
                                     HorizontalAlignment="Center" 
                                     VerticalAlignment="Center"
                                     FontSize="18"/>
                        </Border>
                        <TextBlock Grid.Column="1" 
                                   Text="{Binding Name}" 
                                   FontWeight="Medium"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                        <TextBlock Grid.Column="2" 
                                   Text="&#x203A;" 
                                   FontSize="18"
                                   Foreground="{DynamicResource AppTextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                      </Grid>
                    </Border>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Border>
        </StackPanel>

        <!-- Local Models Section -->
        <StackPanel Spacing="8" 
                    IsVisible="{Binding LocalProviders.Count}">
          <TextBlock Text="&#x1F5A5; 本地模型" 
                     Classes="section-title"/>
          <Border Background="{DynamicResource AppCardBrush}"
                  CornerRadius="12">
            <ItemsControl ItemsSource="{Binding LocalProviders}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="model:AIProvider">
                  <Button Command="{Binding $parent[ItemsControl].((vm:ProviderSelectionViewModel)DataContext).SelectProviderCommand}"
                          CommandParameter="{Binding}"
                          Background="Transparent" 
                          BorderThickness="0"
                          HorizontalAlignment="Stretch" 
                          HorizontalContentAlignment="Left">
                    <Border Padding="12">
                      <Grid ColumnDefinitions="Auto, *, Auto">
                        <Border Width="40" Height="40" 
                                CornerRadius="20"
                                Background="{DynamicResource AppSurfaceBrush}"
                                Margin="0,0,12,0">
                          <TextBlock Text="{Binding Icon}" 
                                     HorizontalAlignment="Center" 
                                     VerticalAlignment="Center"
                                     FontSize="18"/>
                        </Border>
                        <TextBlock Grid.Column="1" 
                                   Text="{Binding Name}" 
                                   FontWeight="Medium"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                        <TextBlock Grid.Column="2" 
                                   Text="&#x203A;" 
                                   FontSize="18"
                                   Foreground="{DynamicResource AppTextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                      </Grid>
                    </Border>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Border>
        </StackPanel>

      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
