<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Asakumo.Avalonia.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:Class="Asakumo.Avalonia.Views.ApiKeyConfigView"
             x:DataType="vm:ApiKeyConfigViewModel"
             Background="{DynamicResource AppBackgroundBrush}">

  <Grid RowDefinitions="Auto, *">
    <!-- Header -->
    <Border Grid.Row="0" 
            Background="{DynamicResource AppBackgroundBrush}"
            Padding="8,8" Height="56">
      <Grid ColumnDefinitions="Auto, *, Auto">
        <Button Grid.Column="0" 
                Command="{Binding GoBackCommand}"
                Classes="icon">
          <TextBlock Text="&#x2190;" FontSize="20"/>
        </Button>
        <StackPanel Grid.Column="1" 
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
          <TextBlock FontSize="18" FontWeight="SemiBold"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource AppTextPrimaryBrush}">
            <Run Text="配置 "/>
            <Run Text="{Binding ProviderName}"/>
          </TextBlock>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Content -->
    <ScrollViewer Grid.Row="1" 
                  Background="{DynamicResource AppBackgroundBrush}">
      <StackPanel Spacing="20" Margin="16">

        <!-- Provider Header Card -->
        <Border Background="{DynamicResource AppCardBrush}"
                CornerRadius="16" 
                Padding="24,20" 
                HorizontalAlignment="Center">
          <StackPanel Spacing="12">
            <Border Width="64" Height="64" 
                    CornerRadius="32"
                    Background="{DynamicResource PrimaryBrush}"
                    HorizontalAlignment="Center">
              <TextBlock Text="{Binding ProviderIcon}" 
                         FontSize="32" 
                         HorizontalAlignment="Center" 
                         VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="{Binding ProviderName}" 
                       FontSize="18" 
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource AppTextPrimaryBrush}"/>
          </StackPanel>
        </Border>

        <!-- API Key Input -->
        <StackPanel Spacing="8">
          <TextBlock Text="API Key *" 
                     FontWeight="Medium"
                     Foreground="{DynamicResource AppTextPrimaryBrush}"/>
          <Border Background="{DynamicResource AppSurfaceBrush}"
                  CornerRadius="8"
                  BorderBrush="{DynamicResource AppBorderBrush}"
                  BorderThickness="1">
            <Grid ColumnDefinitions="*, Auto">
              <TextBox Grid.Column="0"
                       Text="{Binding ApiKey}"
                       PasswordChar="&#x2022;"
                       IsVisible="{Binding !IsApiKeyVisible}"
                       Watermark="sk-..."
                       BorderThickness="0"
                       Background="Transparent"
                       Padding="12,10"/>
              <TextBox Grid.Column="0"
                       Text="{Binding ApiKey}"
                       IsVisible="{Binding IsApiKeyVisible}"
                       Watermark="sk-..."
                       BorderThickness="0"
                       Background="Transparent"
                       Padding="12,10"/>
              <Button Grid.Column="1" 
                      Command="{Binding ToggleApiKeyVisibilityCommand}"
                      Classes="icon">
                <TextBlock Text="&#x1F441;" FontSize="16"/>
              </Button>
            </Grid>
          </Border>
          <Button Background="Transparent" 
                  BorderThickness="0" 
                  HorizontalAlignment="Left"
                  Padding="0">
            <TextBlock Text="在官网获取 API Key" 
                       FontSize="12"
                       Foreground="{DynamicResource PrimaryBrush}"
                       TextDecorations="Underline"/>
          </Button>
        </StackPanel>

        <!-- Base URL Input -->
        <StackPanel Spacing="8">
          <TextBlock Text="Base URL (可选)" 
                     FontWeight="Medium"
                     Foreground="{DynamicResource AppTextPrimaryBrush}"/>
          <Border Background="{DynamicResource AppSurfaceBrush}"
                  CornerRadius="8"
                  BorderBrush="{DynamicResource AppBorderBrush}"
                  BorderThickness="1">
            <TextBox Text="{Binding BaseUrl}"
                     Watermark="https://api.openai.com/v1"
                     BorderThickness="0"
                     Background="Transparent"
                     Padding="12,10"/>
          </Border>
        </StackPanel>

        <!-- Advanced Settings Toggle -->
        <Button Command="{Binding ToggleAdvancedSettingsCommand}"
                Background="Transparent" 
                BorderThickness="0" 
                HorizontalAlignment="Left"
                Padding="0">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="&#x25B6;" FontSize="10"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                       IsVisible="{Binding !ShowAdvancedSettings}"/>
            <TextBlock Text="&#x25BC;" FontSize="10"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                       IsVisible="{Binding ShowAdvancedSettings}"/>
            <TextBlock Text="高级设置" 
                       Foreground="{DynamicResource AppTextSecondaryBrush}"/>
          </StackPanel>
        </Button>

        <!-- Advanced Settings Panel -->
        <Border IsVisible="{Binding ShowAdvancedSettings}" 
                Margin="0,8,0,0"
                Background="{DynamicResource AppSurfaceBrush}"
                Padding="12"
                CornerRadius="8">
          <StackPanel Spacing="12">
            <TextBlock Text="代理设置" 
                       Classes="caption"/>
            <Border Background="{DynamicResource AppBackgroundBrush}"
                    CornerRadius="6"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1">
              <TextBox Watermark="http://localhost:7890"
                       BorderThickness="0"
                       Background="Transparent"
                       Padding="10,8"/>
            </Border>
            <TextBlock Text="请求超时（秒）" 
                       Classes="caption"
                       Margin="0,8,0,0"/>
            <NumericUpDown Value="60" 
                           Minimum="10" 
                           Maximum="300"
                           Background="{DynamicResource AppBackgroundBrush}"/>
          </StackPanel>
        </Border>

        <!-- Validate Button -->
        <Button Command="{Binding ValidateAndSaveCommand}"
                Classes="primary"
                HorizontalAlignment="Stretch" 
                HorizontalContentAlignment="Center"
                Margin="0,20,0,0"
                IsEnabled="{Binding !IsValidating}">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="验证并保存" Foreground="White" FontWeight="SemiBold"/>
            <ProgressBar IsIndeterminate="True" 
                         IsVisible="{Binding IsValidating}"
                         Width="16" Height="16"
                         Foreground="White"/>
          </StackPanel>
        </Button>

      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>