<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Asakumo.Avalonia.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:Class="Asakumo.Avalonia.Views.ApiKeyConfigView"
             x:DataType="vm:ApiKeyConfigViewModel"
             Background="{DynamicResource AppBackgroundBrush}">

  <Grid RowDefinitions="Auto, *">
    <!-- Header -->
    <Border Grid.Row="0" 
            Background="{DynamicResource AppBackgroundBrush}"
            Padding="8,8" Height="56">
      <Grid ColumnDefinitions="Auto, *, Auto">
        <Button Grid.Column="0" 
                Command="{Binding GoBackCommand}"
                Classes="icon">
          <TextBlock Text="&#x2190;" FontSize="20"/>
        </Button>
        <StackPanel Grid.Column="1" 
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
          <TextBlock FontSize="18" FontWeight="SemiBold"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource AppTextPrimaryBrush}">
            <Run Text="配置 "/>
            <Run Text="{Binding ProviderName}"/>
          </TextBlock>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Content -->
    <ScrollViewer Grid.Row="1" 
                  Background="{DynamicResource AppBackgroundBrush}">
      <StackPanel Spacing="16" Margin="16">

        <!-- Provider Header Card -->
        <Border Background="{DynamicResource AppCardBrush}"
                CornerRadius="16" 
                Padding="24,20" 
                HorizontalAlignment="Center">
          <StackPanel Spacing="12">
            <Border Width="64" Height="64" 
                    CornerRadius="32"
                    Background="{DynamicResource PrimaryBrush}"
                    HorizontalAlignment="Center">
              <TextBlock Text="{Binding ProviderIcon}" 
                         FontSize="32" 
                         HorizontalAlignment="Center" 
                         VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="{Binding ProviderName}" 
                       FontSize="18" 
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource AppTextPrimaryBrush}"/>
          </StackPanel>
        </Border>

        <!-- API Key Input -->
        <StackPanel Spacing="8">
          <TextBlock Text="API Key *" 
                     FontWeight="Medium"
                     Foreground="{DynamicResource AppTextPrimaryBrush}"/>
          <Border Background="{DynamicResource AppSurfaceBrush}"
                  CornerRadius="8"
                  BorderBrush="{DynamicResource AppBorderBrush}"
                  BorderThickness="1">
            <Grid ColumnDefinitions="*, Auto">
              <TextBox Grid.Column="0"
                       Text="{Binding ApiKey}"
                       PasswordChar="&#x2022;"
                       IsVisible="{Binding !IsApiKeyVisible}"
                       Watermark="sk-..."
                       BorderThickness="0"
                       Background="Transparent"
                       Padding="12,10"/>
              <TextBox Grid.Column="0"
                       Text="{Binding ApiKey}"
                       IsVisible="{Binding IsApiKeyVisible}"
                       Watermark="sk-..."
                       BorderThickness="0"
                       Background="Transparent"
                       Padding="12,10"/>
              <Button Grid.Column="1" 
                      Command="{Binding ToggleApiKeyVisibilityCommand}"
                      Classes="icon">
                <TextBlock Text="&#x1F441;" FontSize="16"/>
              </Button>
            </Grid>
          </Border>
          <Button Background="Transparent" 
                  BorderThickness="0" 
                  HorizontalAlignment="Left"
                  Padding="0">
            <TextBlock Text="在官网获取 API Key" 
                       FontSize="12"
                       Foreground="{DynamicResource PrimaryBrush}"
                       TextDecorations="Underline"/>
          </Button>
        </StackPanel>

        <!-- Base URL Input -->
        <StackPanel Spacing="8">
          <TextBlock Text="Base URL (可选)" 
                     FontWeight="Medium"
                     Foreground="{DynamicResource AppTextPrimaryBrush}"/>
          <Border Background="{DynamicResource AppSurfaceBrush}"
                  CornerRadius="8"
                  BorderBrush="{DynamicResource AppBorderBrush}"
                  BorderThickness="1">
            <TextBox Text="{Binding BaseUrl}"
                     Watermark="https://api.openai.com/v1"
                     BorderThickness="0"
                     Background="Transparent"
                     Padding="12,10"/>
          </Border>
        </StackPanel>

        <!-- Advanced Settings Toggle -->
        <Button Command="{Binding ToggleAdvancedSettingsCommand}"
                Background="Transparent" 
                BorderThickness="0" 
                HorizontalAlignment="Left"
                Padding="0">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="&#x25B6;" FontSize="10"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                       IsVisible="{Binding !ShowAdvancedSettings}"/>
            <TextBlock Text="&#x25BC;" FontSize="10"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                       IsVisible="{Binding ShowAdvancedSettings}"/>
            <TextBlock Text="高级设置" 
                       Foreground="{DynamicResource AppTextSecondaryBrush}"/>
          </StackPanel>
        </Button>

        <!-- Advanced Settings Panel -->
        <Border IsVisible="{Binding ShowAdvancedSettings}" 
                Margin="0,8,0,0"
                Background="{DynamicResource AppSurfaceBrush}"
                Padding="12"
                CornerRadius="8">
          <StackPanel Spacing="12">
            <TextBlock Text="代理设置" 
                       Classes="caption"/>
            <Border Background="{DynamicResource AppBackgroundBrush}"
                    CornerRadius="6"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1">
              <TextBox Watermark="http://localhost:7890"
                       BorderThickness="0"
                       Background="Transparent"
                       Padding="10,8"/>
            </Border>
            <TextBlock Text="请求超时（秒）" 
                       Classes="caption"
                       Margin="0,8,0,0"/>
            <NumericUpDown Value="60" 
                           Minimum="10" 
                           Maximum="300"
                           Background="{DynamicResource AppBackgroundBrush}"/>
          </StackPanel>
        </Border>

        <!-- Error Card -->
        <Border IsVisible="{Binding HasError}"
                Background="#1FFF0000"
                CornerRadius="12"
                Padding="16,12"
                BorderBrush="#3FFF0000"
                BorderThickness="1">
          <Grid ColumnDefinitions="*, Auto">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="&#x26A0;" FontSize="18" VerticalAlignment="Center"/>
              <TextBlock Text="{Binding ErrorMessage}"
                         TextWrapping="Wrap"
                         VerticalAlignment="Center"
                         Foreground="{DynamicResource AppTextPrimaryBrush}"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Command="{Binding DismissErrorCommand}"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="4">
              <TextBlock Text="&#x2715;" FontSize="14" 
                         Foreground="{DynamicResource AppTextSecondaryBrush}"/>
            </Button>
          </Grid>
        </Border>

        <!-- Fetch Models Button (shown when not loaded) -->
        <Button Command="{Binding FetchModelsCommand}"
                Classes="primary"
                HorizontalAlignment="Stretch" 
                HorizontalContentAlignment="Center"
                Margin="0,8,0,0"
                IsVisible="{Binding !HasLoadedModels}"
                IsEnabled="{Binding !IsLoadingModels}">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="获取模型列表" Foreground="White" FontWeight="SemiBold"/>
            <ProgressBar IsIndeterminate="True" 
                         IsVisible="{Binding IsLoadingModels}"
                         Width="16" Height="16"
                         Foreground="White"/>
          </StackPanel>
        </Button>

        <!-- Models Section (shown when loaded) -->
        <StackPanel IsVisible="{Binding HasLoadedModels}"
                    Spacing="12"
                    Margin="0,8,0,0">

          <!-- Section Header -->
          <Grid ColumnDefinitions="Auto, *, Auto">
            <TextBlock Grid.Column="0"
                       Text="模型列表"
                       FontSize="16"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource AppTextPrimaryBrush}"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding Models.Count, StringFormat='{}{0} 个模型'}"
                       FontSize="12"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"/>
            <CheckBox Grid.Column="2"
                      Content="全选"
                      IsChecked="{Binding SelectAll}"
                      Foreground="{DynamicResource AppTextSecondaryBrush}"/>
          </Grid>

          <!-- Models List -->
          <Border Background="{DynamicResource AppCardBrush}"
                  CornerRadius="12"
                  MaxHeight="300">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding Models}"
                            Margin="8">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:ModelSelectionItemViewModel">
                    <Border Background="{DynamicResource AppSurfaceBrush}"
                            CornerRadius="8"
                            Padding="12,10"
                            Margin="0,0,0,6">
                      <Grid ColumnDefinitions="Auto, *">
                        <CheckBox Grid.Column="0"
                                  IsChecked="{Binding IsSelected}"
                                  Margin="0,0,12,0"/>
                        <StackPanel Grid.Column="1" Spacing="2">
                          <TextBlock Text="{Binding Name}"
                                     FontSize="14"
                                     FontWeight="Medium"
                                     Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                          <TextBlock Text="{Binding Description}"
                                     FontSize="11"
                                     Opacity="0.7"
                                     TextTrimming="CharacterEllipsis"
                                     Foreground="{DynamicResource AppTextSecondaryBrush}"
                                     IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                          <TextBlock Text="{Binding Id}"
                                     FontSize="10"
                                     Opacity="0.5"
                                     FontFamily="Consolas"
                                     Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Border>

          <!-- Refresh & Save Buttons -->
          <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
            <Button Grid.Column="0"
                    Command="{Binding FetchModelsCommand}"
                    Classes="secondary"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    IsEnabled="{Binding !IsLoadingModels}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"
                          Width="16" Height="16"/>
                <TextBlock Text="刷新列表"/>
              </StackPanel>
            </Button>

            <Button Grid.Column="1"
                    Command="{Binding SaveModelsCommand}"
                    Classes="primary"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center">
              <TextBlock Text="保存配置" Foreground="White" FontWeight="SemiBold"/>
            </Button>
          </Grid>
        </StackPanel>

      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
