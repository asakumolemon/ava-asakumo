<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Asakumo.Avalonia.ViewModels"
             xmlns:model="using:Asakumo.Avalonia.Models"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:Class="Asakumo.Avalonia.Views.ChatView"
             x:DataType="vm:ChatViewModel">

  <Grid RowDefinitions="Auto, Auto, *, Auto">
    <!-- Header -->
    <Border Grid.Row="0" Background="{DynamicResource SystemChromeLowColor}"
            Padding="16,12">
      <Grid ColumnDefinitions="Auto, *, Auto">
        <Button Grid.Column="0" Command="{Binding GoBackCommand}"
                Background="Transparent" BorderThickness="0" Padding="8">
          <TextBlock Text="←" FontSize="18"/>
        </Button>
        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
          <TextBlock Text="{Binding Title}" FontWeight="Medium"
                     HorizontalAlignment="Center"/>
          <TextBlock Text="{Binding CurrentModel}" FontSize="12"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                     IsVisible="{Binding CurrentModel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        </StackPanel>
        <Button Grid.Column="2" Background="Transparent" BorderThickness="0" Padding="8">
          <TextBlock Text="⋮" FontSize="18"/>
        </Button>
      </Grid>
    </Border>

    <!-- Success Message -->
    <Border Grid.Row="1" Background="#10B981" Padding="16,12"
            IsVisible="{Binding ShowSuccessMessage}">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
        <TextBlock Text="✅" Foreground="White"/>
        <TextBlock Text="配置成功！现在可以开始聊天了" Foreground="White" FontWeight="Medium"/>
      </StackPanel>
    </Border>

    <!-- Chat Messages -->
    <ScrollViewer Grid.Row="2" Background="{DynamicResource SystemChromeLowColor}">
      <ItemsControl ItemsSource="{Binding Messages}" Margin="16">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="model:ChatMessage">
            <Grid>
              <!-- User Message (Right aligned) -->
              <Border IsVisible="{Binding IsUser}"
                      Background="#10A37F" CornerRadius="16,4,16,16"
                      Padding="12,8" Margin="0,4,0,4"
                      HorizontalAlignment="Right" MaxWidth="280">
                <StackPanel Spacing="4">
                  <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Foreground="White"/>
                  <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                             FontSize="10" Foreground="#FFFFFF99" HorizontalAlignment="Right"/>
                </StackPanel>
              </Border>

              <!-- AI Message (Left aligned) -->
              <Grid IsVisible="{Binding !IsUser}" Margin="0,4,0,4" ColumnDefinitions="Auto, *">
                <Border Grid.Column="0" Background="{DynamicResource SystemAccentColor}"
                        Width="32" Height="32" CornerRadius="16" Margin="0,0,8,0"
                        VerticalAlignment="Top">
                  <TextBlock Text="🤖" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Column="1" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                        CornerRadius="4,16,16,16" Padding="12,8" MaxWidth="280"
                        HorizontalAlignment="Left">
                  <StackPanel Spacing="4">
                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                               FontSize="10" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               HorizontalAlignment="Right"/>
                  </StackPanel>
                </Border>
              </Grid>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <!-- Empty State / Input Area -->
    <Border Grid.Row="3" Background="{DynamicResource SystemChromeMediumColor}"
            Padding="16,12">
      <Grid RowDefinitions="*, Auto">
        <!-- Error Dialog -->
        <Border Grid.Row="0" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                CornerRadius="12" Padding="16" Margin="0,0,0,12"
                IsVisible="{Binding ShowErrorDialog}">
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="⚠️" FontSize="20"/>
              <TextBlock Text="无法发送消息" FontWeight="SemiBold" FontSize="16"/>
            </StackPanel>
            <TextBlock Text="您还没有配置 AI 服务提供商。请先配置 API 设置。"
                       TextWrapping="Wrap"/>
            <Grid ColumnDefinitions="*, *" Margin="0,8,0,0">
              <Button Grid.Column="0" Command="{Binding CloseErrorDialogCommand}"
                      HorizontalAlignment="Center" CornerRadius="8"
                      Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
                <TextBlock Text="稍后"/>
              </Button>
              <Button Grid.Column="1" Command="{Binding ConfigureProviderCommand}"
                      HorizontalAlignment="Center" CornerRadius="8"
                      Background="{DynamicResource SystemAccentColor}">
                <TextBlock Text="立即配置" Foreground="White"/>
              </Button>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Input Area -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto, *, Auto">
          <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Padding="8">
            <TextBlock Text="📎" FontSize="18"/>
          </Button>
          <TextBox Grid.Column="1" Text="{Binding InputMessage}"
                   Watermark="输入消息..."
                   AcceptsReturn="True" TextWrapping="Wrap"
                   MaxHeight="100"
                   BorderThickness="0"
                   Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                   CornerRadius="20" Padding="12,8"/>
          <Button Grid.Column="2" Command="{Binding SendMessageCommand}"
                  Background="{DynamicResource SystemAccentColor}"
                  CornerRadius="20" Padding="12,8" Margin="8,0,0,0"
                  IsEnabled="{Binding !IsAiResponding}">
            <TextBlock Text="发送" Foreground="White"/>
          </Button>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</UserControl>