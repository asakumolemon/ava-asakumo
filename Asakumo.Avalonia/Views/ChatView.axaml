<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Asakumo.Avalonia.ViewModels"
             xmlns:model="using:Asakumo.Avalonia.Models"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:Class="Asakumo.Avalonia.Views.ChatView"
             x:DataType="vm:ChatViewModel"
             Background="{DynamicResource AppBackgroundBrush}">

  <UserControl.KeyBindings>
    <KeyBinding Gesture="Enter" Command="{Binding SendMessageCommand}"/>
  </UserControl.KeyBindings>

  <Grid RowDefinitions="Auto, *, Auto">
    <!-- Header -->
    <Border Grid.Row="0" Background="{DynamicResource AppBackgroundBrush}" Padding="12,8">
      <Grid ColumnDefinitions="Auto, *, Auto">
        <Button Grid.Column="0"
                Command="{Binding GoBackCommand}"
                Classes="icon"
                ToolTip.Tip="返回">
          <PathIcon Data="M20,11H7.83L13.42,5.41L12,4L4,12L12,20L13.41,18.59L7.83,13H20V11Z"
                    Width="20" Height="20"/>
        </Button>

        <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
          <!-- Normal Title Display -->
          <TextBlock Text="{Binding Title}"
                     FontWeight="SemiBold" FontSize="16"
                     HorizontalAlignment="Center"
                     TextTrimming="CharacterEllipsis"
                     MaxWidth="200"
                     Foreground="{DynamicResource AppTextPrimaryBrush}"
                     IsVisible="{Binding !IsEditingTitle}"/>

          <!-- Title Edit Mode -->
          <StackPanel IsVisible="{Binding IsEditingTitle}"
                      Orientation="Horizontal" Spacing="8">
            <TextBox Text="{Binding EditableTitle}"
                     Width="150"
                     FontSize="14"/>
            <Button Classes="icon" Width="28" Height="28"
                    Command="{Binding SaveTitleCommand}">
              <PathIcon Data="M9,16.17L4.83,12L3.41,13.41L9,19L21,7L19.59,5.59L9,16.17Z"
                        Width="16" Height="16"/>
            </Button>
            <Button Classes="icon" Width="28" Height="28"
                    Command="{Binding CancelRenameTitleCommand}">
              <PathIcon Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                        Width="16" Height="16"/>
            </Button>
          </StackPanel>

          <Border Background="{DynamicResource AppSurfaceBrush}"
                  CornerRadius="8"
                  Padding="8,2"
                  IsVisible="{Binding CurrentModel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                  HorizontalAlignment="Center">
            <TextBlock Text="{Binding CurrentModel}"
                       FontSize="11"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"/>
          </Border>
        </StackPanel>

        <Button Grid.Column="2"
                Classes="icon"
                ToolTip.Tip="更多选项"
                Command="{Binding OpenMoreMenuCommand}">
          <PathIcon Data="M12,16A2,2 0 0,1 14,18A2,2 0 0,1 12,20A2,2 0 0,1 10,18A2,2 0 0,1 12,16M12,10A2,2 0 0,1 14,12A2,2 0 0,1 12,14A2,2 0 0,1 10,12A2,2 0 0,1 12,10M12,4A2,2 0 0,1 14,6A2,2 0 0,1 12,8A2,2 0 0,1 10,6A2,2 0 0,1 12,4Z"
                    Width="20" Height="20"/>
        </Button>
      </Grid>
    </Border>

    <!-- Success Banner -->
    <Border Grid.Row="0"
            Background="{DynamicResource SuccessBrush}"
            Padding="16,12"
            IsVisible="{Binding ShowSuccessMessage}"
            CornerRadius="0"
            ZIndex="10">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
        <PathIcon Data="M9,16.17L4.83,12L3.41,13.41L9,19L21,7L19.59,5.59L9,16.17Z"
                  Width="16" Height="16" Foreground="White"/>
        <TextBlock Text="配置成功，可以开始聊天了" Foreground="White" FontWeight="Medium"/>
      </StackPanel>
    </Border>

    <!-- More Menu Popup -->
    <Border Grid.Row="1"
            Background="{DynamicResource AppCardBrush}"
            CornerRadius="12"
            Padding="8"
            Margin="0,56,12,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            IsVisible="{Binding IsMoreMenuOpen}"
            ZIndex="100"
            BoxShadow="0 4 16 0 #40000000">
      <StackPanel Width="180" Spacing="4">
        <Button Classes="menu-item"
                Command="{Binding RenameConversationCommand}">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <PathIcon Data="M3,17.25V21H6.75L17.81,9.94L14.06,6.19L3,17.25M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.13,5.12L18.88,8.87L20.71,7.04Z"
                      Width="18" Height="18"/>
            <TextBlock Text="重命名" Classes="body"/>
          </StackPanel>
        </Button>
        <Button Classes="menu-item"
                Command="{Binding ClearCurrentConversationCommand}">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <PathIcon Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19V4M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                      Width="18" Height="18"/>
            <TextBlock Text="清空会话" Classes="body"/>
          </StackPanel>
        </Button>
        <Button Classes="menu-item"
                Command="{Binding ExportConversationCommand}">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <PathIcon Data="M19,9H15V3H9V9H5L12,16L19,9M5,18V20H19V18H5Z"
                      Width="18" Height="18"/>
            <TextBlock Text="导出对话" Classes="body"/>
          </StackPanel>
        </Button>
        <Separator Margin="0,4"/>
        <Button Classes="menu-item"
                Command="{Binding NavigateToSettingsCommand}">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <PathIcon Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                      Width="18" Height="18"/>
            <TextBlock Text="设置" Classes="body"/>
          </StackPanel>
        </Button>
      </StackPanel>
    </Border>

    <!-- Chat Area -->
    <Grid Grid.Row="1" Background="{DynamicResource AppBackgroundBrush}">
      <!-- Empty State -->
      <StackPanel IsVisible="{Binding !HasMessages}"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Center"
                  Spacing="16">
        <Border Background="{DynamicResource AppSurfaceBrush}"
                Width="80" Height="80"
                CornerRadius="40">
          <PathIcon Data="M20,2H4A2,2 0 0,0 2,4V22L6,18H20A2,2 0 0,0 22,16V4A2,2 0 0,0 20,2M20,16H6L4,18V4H20V16Z"
                    Width="36" Height="36"
                    Foreground="{DynamicResource AppTextSecondaryBrush}"/>
        </Border>
        <TextBlock Text="开始新对话"
                   FontSize="18" FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Foreground="{DynamicResource AppTextPrimaryBrush}"/>
        <TextBlock Text="发送消息开始与 AI 交流"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   Foreground="{DynamicResource AppTextSecondaryBrush}"/>
      </StackPanel>

      <!-- Messages List (ListBox with virtualization) -->
      <ListBox ItemsSource="{Binding Messages}"
               Background="Transparent"
               BorderThickness="0"
               Padding="16,8"
               IsVisible="{Binding HasMessages}"
               ScrollViewer.HorizontalScrollBarVisibility="Disabled"
               x:Name="MessagesListBox">
        <ListBox.Styles>
          <!-- Remove default ListBox item selection visuals -->
          <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
          </Style>
          <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="Transparent"/>
          </Style>
          <Style Selector="ListBoxItem:pointerover">
            <Setter Property="Background" Value="Transparent"/>
          </Style>
          <!-- Menu Item Button Style -->
          <Style Selector="Button.menu-item">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
          </Style>
          <Style Selector="Button.menu-item:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
          </Style>
        </ListBox.Styles>
        <ListBox.ItemsPanel>
          <ItemsPanelTemplate>
            <VirtualizingStackPanel />
          </ItemsPanelTemplate>
        </ListBox.ItemsPanel>
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="model:ChatMessage">
                      <!-- Message Container with Interleaved Layout -->
                      <!-- Left spacer (8*) creates larger gap for user messages -->
                      <!-- Right spacer (4*) creates smaller gap for AI messages -->
                      <Grid Margin="0,4" ColumnDefinitions="8*, Auto, 4*">
                        <!-- User Message (Right side, occupies columns 1-2) -->
                        <Grid Grid.Column="1"
                              Grid.ColumnSpan="2"
                              IsVisible="{Binding IsUser}"
                              HorizontalAlignment="Right">
                          <!-- Edit Mode -->
                          <Border IsVisible="{Binding IsEditing}"
                                  Background="{DynamicResource AppUserMessageBrush}"
                                  CornerRadius="16,4,16,16"
                                  Padding="12,8"
                                  HorizontalAlignment="Right">
                            <StackPanel Spacing="8">
                              <TextBox Text="{Binding EditableContent}"
                                       AcceptsReturn="True" TextWrapping="Wrap"
                                       MinWidth="150"/>
                              <StackPanel Orientation="Horizontal"
                                          HorizontalAlignment="Right" Spacing="8">
                                <Button Content="取消" Classes="secondary"
                                        Command="{Binding $parent[ListBox].((vm:ChatViewModel)DataContext).CancelEditMessageCommand}"
                                        CommandParameter="{Binding}"/>
                                <Button Content="保存" Classes="primary"
                                        Command="{Binding $parent[ListBox].((vm:ChatViewModel)DataContext).SaveEditedMessageCommand}"
                                        CommandParameter="{Binding}"/>
                              </StackPanel>
                            </StackPanel>
                          </Border>
        
                          <!-- Normal Mode -->
                          <Border IsVisible="{Binding !IsEditing}"
                                  Background="{DynamicResource AppUserMessageBrush}"
                                  CornerRadius="16,4,16,16"
                                  Padding="12,8"
                                  HorizontalAlignment="Right">
                            <StackPanel Spacing="4">
                              <TextBlock Text="{Binding Content}"
                                         TextWrapping="Wrap"
                                         Foreground="White" FontSize="14"/>
                              <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                           FontSize="10" Foreground="#CCFFFFFF"/>
                                <StackPanel Orientation="Horizontal" Spacing="4" Opacity="0.7">
                                                                                          <Button Classes="icon" Width="24" Height="24" Padding="4"
                                                                                                  Command="{Binding $parent[ListBox].((vm:ChatViewModel)DataContext).CopyMessageCommand}"
                                                                                                  CommandParameter="{Binding}"
                                                                                                  ToolTip.Tip="复制">
                                                                                            <PathIcon Data="M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M19,21H8V7H19V21Z"
                                                                                                      Width="12" Height="12" Foreground="White"/>
                                                                                          </Button>                                  <Button Classes="icon" Width="24" Height="24" Padding="4"
                                          Command="{Binding $parent[ListBox].((vm:ChatViewModel)DataContext).EditMessageCommand}"
                                          CommandParameter="{Binding}"
                                          ToolTip.Tip="编辑">
                                    <PathIcon Data="M3,17.25V21H6.75L17.81,9.94L14.06,6.19L3,17.25M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.13,5.12L18.88,8.87L20.71,7.04Z"
                                              Width="12" Height="12" Foreground="White"/>
                                  </Button>
                                  <Button Classes="icon" Width="24" Height="24" Padding="4"
                                          Command="{Binding $parent[ListBox].((vm:ChatViewModel)DataContext).DeleteMessageCommand}"
                                          CommandParameter="{Binding}"
                                          ToolTip.Tip="删除">
                                    <PathIcon Data="M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19V4Z"
                                              Width="12" Height="12" Foreground="White"/>
                                  </Button>
                                </StackPanel>
                              </StackPanel>
                            </StackPanel>
                          </Border>
                        </Grid>
        
                        <!-- AI Message (Left side, occupies columns 0-1) -->
                        <Grid Grid.Column="0"
                              Grid.ColumnSpan="2"
                              IsVisible="{Binding !IsUser}"
                              ColumnDefinitions="40, *">
                          <!-- AI Avatar (fixed 40px width) -->
                          <Border Grid.Column="0"
                                  Background="{DynamicResource PrimaryBrush}"
                                  Width="32" Height="32"
                                  CornerRadius="16"
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Top">
                            <TextBlock Text="AI"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="White"/>
                          </Border>
        
                          <!-- AI Bubble -->
                          <Border Grid.Column="1"
                                  Background="{DynamicResource AppAiMessageBrush}"
                                  CornerRadius="4,16,16,16"
                                  Padding="12,8"
                                  HorizontalAlignment="Left">                    <StackPanel Spacing="4">
                      <!-- Typing Indicator (only when loading with no content) -->
                      <StackPanel Classes="typing-indicator"
                                  IsVisible="{Binding IsLoading}">
                        <TextBlock Text="思考中"
                                   FontSize="11"
                                   Foreground="{DynamicResource AppTextSecondaryBrush}"
                                   Margin="0,0,8,0"
                                   IsVisible="{Binding !HasContent}"/>
                        <Border Classes="typing-dot"
                                IsVisible="{Binding !HasContent}"/>
                        <Border Classes="typing-dot"
                                IsVisible="{Binding !HasContent}"/>
                        <Border Classes="typing-dot"
                                IsVisible="{Binding !HasContent}"/>
                      </StackPanel>

                      <!-- Error State -->
                      <StackPanel IsVisible="{Binding IsError}" Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                          <PathIcon Data="M12,2C17.53,2 22,6.47 22,12C22,17.53 17.53,22 12,22C6.47,22 2,17.53 2,12C2,6.47 6.47,2 12,2M15.59,7L12,10.59L8.41,7L7,8.41L10.59,12L7,15.59L8.41,17L12,13.41L15.59,17L17,15.59L13.41,12L17,8.41L15.59,7Z"
                                    Width="14" Height="14"
                                    Foreground="{DynamicResource ErrorBrush}"/>
                          <TextBlock Text="发生错误"
                                     FontWeight="Medium"
                                     Foreground="{DynamicResource ErrorBrush}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Content}"
                                   TextWrapping="Wrap" FontSize="13"
                                   Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                        <Button Content="重试" Classes="secondary" Padding="12,6"
                                Command="{Binding $parent[ListBox].((vm:ChatViewModel)DataContext).RetryMessageCommand}"
                                CommandParameter="{Binding}"/>
                      </StackPanel>

                      <!-- Streaming Content (loading with content) -->
                      <StackPanel IsVisible="{Binding IsStreaming}" Spacing="4">
                        <TextBlock Text="{Binding Content}"
                                   TextWrapping="Wrap" FontSize="14"
                                   Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                        <!-- 流式指示器 -->
                        <Border Width="6" Height="6"
                                Background="{DynamicResource PrimaryBrush}"
                                CornerRadius="3"
                                Margin="0,4,0,0"
                                HorizontalAlignment="Left">
                          <Border.Styles>
                            <Style Selector="Border">
                              <Style.Animations>
                                <Animation Duration="0:0:0.6" IterationCount="INFINITE">
                                  <KeyFrame Cue="0%">
                                    <Setter Property="Opacity" Value="0.3"/>
                                  </KeyFrame>
                                  <KeyFrame Cue="50%">
                                    <Setter Property="Opacity" Value="1"/>
                                  </KeyFrame>
                                  <KeyFrame Cue="100%">
                                    <Setter Property="Opacity" Value="0.3"/>
                                  </KeyFrame>
                                </Animation>
                              </Style.Animations>
                            </Style>
                          </Border.Styles>
                        </Border>
                      </StackPanel>

                      <!-- Normal Content (complete, not loading and not error) -->
                      <StackPanel Spacing="4" IsVisible="{Binding IsComplete}">
                        <!-- 使用 TextBlock 显示内容（更可靠） -->
                        <TextBlock Text="{Binding Content, Mode=OneWay}"
                                   TextWrapping="Wrap" FontSize="14"
                                   Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                          <StackPanel Orientation="Horizontal" Spacing="4" Opacity="0.7">
                            <Button Classes="icon" Width="24" Height="24" Padding="4"
                                    Command="{Binding $parent[ListBox].((vm:ChatViewModel)DataContext).CopyMessageCommand}"
                                    CommandParameter="{Binding}"
                                    ToolTip.Tip="复制">
                              <PathIcon Data="M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M19,21H8V7H19V21Z"
                                        Width="12" Height="12"
                                        Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                            </Button>
                            <Button Classes="icon" Width="24" Height="24" Padding="4"
                                    Command="{Binding $parent[ListBox].((vm:ChatViewModel)DataContext).DeleteMessageCommand}"
                                    CommandParameter="{Binding}"
                                    ToolTip.Tip="删除">
                              <PathIcon Data="M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19V4Z"
                                        Width="12" Height="12"
                                        Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                            </Button>
                          </StackPanel>
                          <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                     FontSize="10"
                                     Foreground="{DynamicResource AppTextSecondaryBrush}"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </Grid>
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>

    <!-- Toast Notification -->
    <Border Grid.Row="0" Grid.RowSpan="3"
            Background="#333333"
            CornerRadius="8"
            Padding="16,10"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="0,0,0,100"
            IsVisible="{Binding ShowToast}"
            ZIndex="200"
            Opacity="0.9">
      <TextBlock Text="{Binding ToastMessage}"
                 Foreground="White"
                 FontSize="14"/>
    </Border>

    <!-- Bottom Area -->
    <Border Grid.Row="2"
            Background="{DynamicResource AppBackgroundBrush}"
            Padding="12,12">
      <Grid RowDefinitions="Auto, Auto">
        <!-- Error Dialog -->
        <Border Grid.Row="0"
                Background="{DynamicResource AppCardBrush}"
                CornerRadius="16"
                Padding="16"
                Margin="0,0,0,12"
                IsVisible="{Binding ShowErrorDialog}">
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <PathIcon Data="M13,14H11V10H13M13,18H11V16H13M1,21H23L12,2L1,21Z"
                        Width="20" Height="20"
                        Foreground="{DynamicResource ErrorBrush}"/>
              <TextBlock Text="需要配置 AI 服务"
                         FontWeight="SemiBold" FontSize="16"
                         Foreground="{DynamicResource AppTextPrimaryBrush}"/>
            </StackPanel>
            <TextBlock Text="请先配置 AI 服务提供商和 API 密钥才能开始聊天。"
                       TextWrapping="Wrap" Classes="body"/>
            <Grid ColumnDefinitions="*, *" Margin="0,8,0,0" ColumnSpacing="12">
              <Button Grid.Column="0" Content="稍后"
                      Command="{Binding CloseErrorDialogCommand}"
                      Classes="secondary"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Center"/>
              <Button Grid.Column="1" Content="立即配置"
                      Command="{Binding ConfigureProviderCommand}"
                      Classes="primary"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Center"/>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Input Area -->
        <Border Grid.Row="1"
                Background="{DynamicResource AppSurfaceBrush}"
                CornerRadius="24"
                Padding="4">
          <Grid ColumnDefinitions="Auto, *, Auto" VerticalAlignment="Center">
            <Button Grid.Column="0" Classes="icon"
                    IsVisible="{Binding !IsAiResponding}"
                    ToolTip.Tip="添加附件">
              <PathIcon Data="M16.5,6V17.5A4,4 0 0,1 12.5,21.5A4,4 0 0,1 8.5,17.5V5A2.5,2.5 0 0,1 11,2.5A2.5,2.5 0 0,1 13.5,5V15.5A1,1 0 0,1 12.5,16.5A1,1 0 0,1 11.5,15.5V6H10V15.5A2.5,2.5 0 0,0 12.5,18A2.5,2.5 0 0,0 15,15.5V5A4,4 0 0,0 11,1A4,4 0 0,0 7,5V17.5A5.5,5.5 0 0,0 12.5,23A5.5,5.5 0 0,0 18,17.5V6H16.5Z"
                        Width="18" Height="18"/>
            </Button>

            <TextBox Grid.Column="1"
                     Text="{Binding InputMessage}"
                     Watermark="输入消息... (Shift+Enter 换行)"
                     Classes="chat-input"
                     IsEnabled="{Binding !IsAiResponding}"
                     AcceptsReturn="True"/>

            <!-- Stop Button -->
            <Button Grid.Column="2"
                    Classes="icon"
                    Command="{Binding StopResponseCommand}"
                    IsVisible="{Binding IsAiResponding}"
                    ToolTip.Tip="停止生成">
              <Border Background="{DynamicResource ErrorBrush}"
                      CornerRadius="12"
                      Width="24" Height="24">
                <PathIcon Data="M6,6H18V18H6V6Z"
                          Width="12" Height="12"
                          Foreground="White"/>
              </Border>
            </Button>

            <!-- Send Button -->
            <Button Grid.Column="2"
                    Classes="send"
                    Command="{Binding SendMessageCommand}"
                    IsEnabled="{Binding !IsAiResponding}"
                    IsVisible="{Binding !IsAiResponding}"
                    ToolTip.Tip="发送 (Enter)">
              <PathIcon Data="M2,21L23,12L2,3V10L17,12L2,14V21Z"
                        Width="16" Height="16"
                        Foreground="White"/>
            </Button>
          </Grid>
        </Border>
      </Grid>
    </Border>
  </Grid>
</UserControl>
