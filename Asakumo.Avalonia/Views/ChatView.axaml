<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Asakumo.Avalonia.ViewModels"
             xmlns:model="using:Asakumo.Avalonia.Models"
             xmlns:markdown="clr-namespace:Markdown.Avalonia;assembly=Markdown.Avalonia"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:Class="Asakumo.Avalonia.Views.ChatView"
             x:DataType="vm:ChatViewModel"
             Background="{DynamicResource AppBackgroundBrush}">

  <UserControl.KeyBindings>
    <KeyBinding Gesture="Enter" Command="{Binding SendMessageCommand}"/>
  </UserControl.KeyBindings>

  <Grid RowDefinitions="Auto, *, Auto">
    <!-- Header -->
    <Border Grid.Row="0" Background="{DynamicResource AppBackgroundBrush}" Padding="12,8">
      <Grid ColumnDefinitions="Auto, *, Auto">
        <Button Grid.Column="0"
                Command="{Binding GoBackCommand}"
                Classes="icon"
                ToolTip.Tip="返回">
          <PathIcon Data="M20,11H7.83L13.42,5.41L12,4L4,12L12,20L13.41,18.59L7.83,13H20V11Z"
                    Width="20" Height="20"/>
        </Button>

        <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
          <TextBlock Text="{Binding Title}"
                     FontWeight="SemiBold" FontSize="16"
                     HorizontalAlignment="Center"
                     TextTrimming="CharacterEllipsis"
                     MaxWidth="200"
                     Foreground="{DynamicResource AppTextPrimaryBrush}"/>
          <Border Background="{DynamicResource AppSurfaceBrush}"
                  CornerRadius="8"
                  Padding="8,2"
                  IsVisible="{Binding CurrentModel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                  HorizontalAlignment="Center">
            <TextBlock Text="{Binding CurrentModel}"
                       FontSize="11"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"/>
          </Border>
        </StackPanel>

        <Button Grid.Column="2" Classes="icon" ToolTip.Tip="更多选项">
          <PathIcon Data="M12,16A2,2 0 0,1 14,18A2,2 0 0,1 12,20A2,2 0 0,1 10,18A2,2 0 0,1 12,16M12,10A2,2 0 0,1 14,12A2,2 0 0,1 12,14A2,2 0 0,1 10,12A2,2 0 0,1 12,10M12,4A2,2 0 0,1 14,6A2,2 0 0,1 12,8A2,2 0 0,1 10,6A2,2 0 0,1 12,4Z"
                    Width="20" Height="20"/>
        </Button>
      </Grid>
    </Border>

    <!-- Success Banner -->
    <Border Grid.Row="0"
            Background="{DynamicResource SuccessBrush}"
            Padding="16,12"
            IsVisible="{Binding ShowSuccessMessage}"
            CornerRadius="0"
            ZIndex="10">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
        <PathIcon Data="M9,16.17L4.83,12L3.41,13.41L9,19L21,7L19.59,5.59L9,16.17Z"
                  Width="16" Height="16" Foreground="White"/>
        <TextBlock Text="配置成功，可以开始聊天了" Foreground="White" FontWeight="Medium"/>
      </StackPanel>
    </Border>

    <!-- Chat Area -->
    <ScrollViewer Grid.Row="1"
                  Background="{DynamicResource AppBackgroundBrush}"
                  x:Name="MessagesScrollViewer">
      <Grid Margin="16,16,16,8">
        <!-- Empty State -->
        <StackPanel IsVisible="{Binding !HasMessages}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="16">
          <Border Background="{DynamicResource AppSurfaceBrush}"
                  Width="80" Height="80"
                  CornerRadius="40">
            <PathIcon Data="M20,2H4A2,2 0 0,0 2,4V22L6,18H20A2,2 0 0,0 22,16V4A2,2 0 0,0 20,2M20,16H6L4,18V4H20V16Z"
                      Width="36" Height="36"
                      Foreground="{DynamicResource AppTextSecondaryBrush}"/>
          </Border>
          <TextBlock Text="开始新对话"
                     FontSize="18" FontWeight="SemiBold"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource AppTextPrimaryBrush}"/>
          <TextBlock Text="发送消息开始与 AI 交流"
                     FontSize="14"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource AppTextSecondaryBrush}"/>
        </StackPanel>

        <!-- Messages List -->
        <ItemsControl ItemsSource="{Binding Messages}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="model:ChatMessage">
              <Grid Margin="0,4">
                <!-- User Message (Right aligned) -->
                <Grid IsVisible="{Binding IsUser}"
                      HorizontalAlignment="Right" MaxWidth="300">
                  <!-- Edit Mode -->
                  <Border IsVisible="{Binding IsEditing}"
                          Background="{DynamicResource AppUserMessageBrush}"
                          CornerRadius="16,4,16,16"
                          Padding="12,8">
                    <StackPanel Spacing="8">
                      <TextBox Text="{Binding EditableContent}"
                               AcceptsReturn="True" TextWrapping="Wrap"
                               MinWidth="200" MaxWidth="260"/>
                      <StackPanel Orientation="Horizontal"
                                  HorizontalAlignment="Right" Spacing="8">
                        <Button Content="取消" Classes="secondary"
                                Command="{Binding $parent[ItemsControl].((vm:ChatViewModel)DataContext).CancelEditMessageCommand}"
                                CommandParameter="{Binding}"/>
                        <Button Content="保存" Classes="primary"
                                Command="{Binding $parent[ItemsControl].((vm:ChatViewModel)DataContext).SaveEditedMessageCommand}"
                                CommandParameter="{Binding}"/>
                      </StackPanel>
                    </StackPanel>
                  </Border>

                  <!-- Normal Mode -->
                  <Border IsVisible="{Binding !IsEditing}"
                          Background="{DynamicResource AppUserMessageBrush}"
                          CornerRadius="16,4,16,16"
                          Padding="12,8">
                    <StackPanel Spacing="4">
                      <TextBlock Text="{Binding Content}"
                                 TextWrapping="Wrap"
                                 Foreground="White" FontSize="14"/>
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                   FontSize="10" Foreground="#CCFFFFFF"/>
                        <StackPanel Orientation="Horizontal" Spacing="4" Opacity="0.7">
                          <Button Classes="icon" Width="24" Height="24" Padding="4"
                                  Command="{Binding $parent[ItemsControl].((vm:ChatViewModel)DataContext).EditMessageCommand}"
                                  CommandParameter="{Binding}"
                                  ToolTip.Tip="编辑">
                            <PathIcon Data="M3,17.25V21H6.75L17.81,9.94L14.06,6.19L3,17.25M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.13,5.12L18.88,8.87L20.71,7.04Z"
                                      Width="12" Height="12" Foreground="White"/>
                          </Button>
                          <Button Classes="icon" Width="24" Height="24" Padding="4"
                                  Command="{Binding $parent[ItemsControl].((vm:ChatViewModel)DataContext).DeleteMessageCommand}"
                                  CommandParameter="{Binding}"
                                  ToolTip.Tip="删除">
                            <PathIcon Data="M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19V4Z"
                                      Width="12" Height="12" Foreground="White"/>
                          </Button>
                        </StackPanel>
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </Grid>

                <!-- AI Message (Left aligned with avatar) -->
                <Grid IsVisible="{Binding !IsUser}"
                      ColumnDefinitions="Auto, *" MaxWidth="340">
                  <!-- AI Avatar -->
                  <Border Grid.Column="0"
                          Background="{DynamicResource PrimaryBrush}"
                          Width="32" Height="32"
                          CornerRadius="16"
                          Margin="0,0,8,0"
                          VerticalAlignment="Top">
                    <TextBlock Text="AI"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="11" FontWeight="Bold"
                               Foreground="White"/>
                  </Border>

                  <!-- AI Bubble -->
                  <Border Grid.Column="1"
                          Background="{DynamicResource AppAiMessageBrush}"
                          CornerRadius="4,16,16,16"
                          Padding="12,8"
                          MaxWidth="280"
                          HorizontalAlignment="Left">
                    <StackPanel Spacing="4">
                      <!-- Typing Indicator (only when loading with no content) -->
                      <StackPanel IsVisible="{Binding !HasContent}"
                                  Classes="typing-indicator">
                        <StackPanel.IsVisible>
                          <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="IsLoading"/>
                            <Binding Path="!HasContent"/>
                          </MultiBinding>
                        </StackPanel.IsVisible>
                        <Border Classes="typing-dot"/>
                        <Border Classes="typing-dot"/>
                        <Border Classes="typing-dot"/>
                      </StackPanel>

                      <!-- Error State -->
                      <StackPanel IsVisible="{Binding IsError}" Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                          <PathIcon Data="M12,2C17.53,2 22,6.47 22,12C22,17.53 17.53,22 12,22C6.47,22 2,17.53 2,12C2,6.47 6.47,2 12,2M15.59,7L12,10.59L8.41,7L7,8.41L10.59,12L7,15.59L8.41,17L12,13.41L15.59,17L17,15.59L13.41,12L17,8.41L15.59,7Z"
                                    Width="14" Height="14"
                                    Foreground="{DynamicResource ErrorBrush}"/>
                          <TextBlock Text="发生错误"
                                     FontWeight="Medium"
                                     Foreground="{DynamicResource ErrorBrush}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Content}"
                                   TextWrapping="Wrap" FontSize="13"
                                   Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                        <Button Content="重试" Classes="secondary" Padding="12,6"
                                Command="{Binding $parent[ItemsControl].((vm:ChatViewModel)DataContext).RetryMessageCommand}"
                                CommandParameter="{Binding}"/>
                      </StackPanel>

                      <!-- Streaming Content (loading with content) -->
                      <StackPanel Orientation="Horizontal" IsVisible="{Binding IsStreaming}">
                        <TextBlock Text="{Binding Content}"
                                   TextWrapping="Wrap" FontSize="14"
                                   Foreground="{DynamicResource AppTextPrimaryBrush}"
                                   MaxWidth="250"/>
                        <Border Classes="streaming-cursor"/>
                      </StackPanel>

                      <!-- Normal Content (complete, not loading and not error) -->
                      <StackPanel Spacing="4" IsVisible="{Binding IsComplete}">
                        <markdown:MarkdownScrollViewer Markdown="{Binding Content}"/>
                        <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                   FontSize="10"
                                   Foreground="{DynamicResource AppTextSecondaryBrush}"
                                   HorizontalAlignment="Right"/>
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </Grid>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Grid>
    </ScrollViewer>

    <!-- Bottom Area -->
    <Border Grid.Row="2"
            Background="{DynamicResource AppBackgroundBrush}"
            Padding="12,12">
      <Grid RowDefinitions="Auto, Auto">
        <!-- Error Dialog -->
        <Border Grid.Row="0"
                Background="{DynamicResource AppCardBrush}"
                CornerRadius="16"
                Padding="16"
                Margin="0,0,0,12"
                IsVisible="{Binding ShowErrorDialog}">
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <PathIcon Data="M13,14H11V10H13M13,18H11V16H13M1,21H23L12,2L1,21Z"
                        Width="20" Height="20"
                        Foreground="{DynamicResource ErrorBrush}"/>
              <TextBlock Text="需要配置 AI 服务"
                         FontWeight="SemiBold" FontSize="16"
                         Foreground="{DynamicResource AppTextPrimaryBrush}"/>
            </StackPanel>
            <TextBlock Text="请先配置 AI 服务提供商和 API 密钥才能开始聊天。"
                       TextWrapping="Wrap" Classes="body"/>
            <Grid ColumnDefinitions="*, *" Margin="0,8,0,0" ColumnSpacing="12">
              <Button Grid.Column="0" Content="稍后"
                      Command="{Binding CloseErrorDialogCommand}"
                      Classes="secondary"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Center"/>
              <Button Grid.Column="1" Content="立即配置"
                      Command="{Binding ConfigureProviderCommand}"
                      Classes="primary"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Center"/>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Input Area -->
        <Border Grid.Row="1"
                Background="{DynamicResource AppSurfaceBrush}"
                CornerRadius="24"
                Padding="4">
          <Grid ColumnDefinitions="Auto, *, Auto" VerticalAlignment="Center">
            <Button Grid.Column="0" Classes="icon"
                    IsVisible="{Binding !IsAiResponding}"
                    ToolTip.Tip="添加附件">
              <PathIcon Data="M16.5,6V17.5A4,4 0 0,1 12.5,21.5A4,4 0 0,1 8.5,17.5V5A2.5,2.5 0 0,1 11,2.5A2.5,2.5 0 0,1 13.5,5V15.5A1,1 0 0,1 12.5,16.5A1,1 0 0,1 11.5,15.5V6H10V15.5A2.5,2.5 0 0,0 12.5,18A2.5,2.5 0 0,0 15,15.5V5A4,4 0 0,0 11,1A4,4 0 0,0 7,5V17.5A5.5,5.5 0 0,0 12.5,23A5.5,5.5 0 0,0 18,17.5V6H16.5Z"
                        Width="18" Height="18"/>
            </Button>

            <TextBox Grid.Column="1"
                     Text="{Binding InputMessage}"
                     Watermark="输入消息... (Shift+Enter 换行)"
                     Classes="chat-input"
                     IsEnabled="{Binding !IsAiResponding}"
                     AcceptsReturn="True"/>

            <!-- Stop Button -->
            <Button Grid.Column="2"
                    Classes="icon"
                    Command="{Binding StopResponseCommand}"
                    IsVisible="{Binding IsAiResponding}"
                    ToolTip.Tip="停止生成">
              <Border Background="{DynamicResource ErrorBrush}"
                      CornerRadius="12"
                      Width="24" Height="24">
                <PathIcon Data="M6,6H18V18H6V6Z"
                          Width="12" Height="12"
                          Foreground="White"/>
              </Border>
            </Button>

            <!-- Send Button -->
            <Button Grid.Column="2"
                    Classes="send"
                    Command="{Binding SendMessageCommand}"
                    IsEnabled="{Binding !IsAiResponding}"
                    IsVisible="{Binding !IsAiResponding}"
                    ToolTip.Tip="发送 (Enter)">
              <PathIcon Data="M2,21L23,12L2,3V10L17,12L2,14V21Z"
                        Width="16" Height="16"
                        Foreground="White"/>
            </Button>
          </Grid>
        </Border>
      </Grid>
    </Border>
  </Grid>
</UserControl>
