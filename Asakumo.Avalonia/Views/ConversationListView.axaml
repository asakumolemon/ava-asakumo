<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Asakumo.Avalonia.ViewModels"
             xmlns:model="using:Asakumo.Avalonia.Models"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:Class="Asakumo.Avalonia.Views.ConversationListView"
             x:DataType="vm:ConversationListViewModel"
             x:Name="ConversationListControl"
             Background="{DynamicResource AppBackgroundBrush}">

  <Grid RowDefinitions="Auto, *, Auto">
    <!-- Header -->
    <Border Grid.Row="0" Background="{DynamicResource AppBackgroundBrush}"
            Padding="16,16" Height="60">
      <Grid ColumnDefinitions="*, Auto">
        <TextBlock Grid.Column="0" Text="Asakumo" 
                   Classes="page-title"
                   VerticalAlignment="Center"/>
        <Button Grid.Column="1" Command="{Binding OpenSettingsCommand}"
                Classes="icon">
          <TextBlock Text="&#x2699;" FontSize="20"/>
        </Button>
      </Grid>
    </Border>

    <!-- Content -->
    <ScrollViewer Grid.Row="1">
      <StackPanel Spacing="16" Margin="16">
        <!-- Empty State -->
        <StackPanel IsVisible="{Binding IsEmpty}" 
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center" 
                    Spacing="24" 
                    Margin="0,60,0,0">
          <!-- 空状态插图 -->
          <StackPanel HorizontalAlignment="Center" Spacing="16">
            <TextBlock Text="&#x1F4DD;" FontSize="64" HorizontalAlignment="Center"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"/>
            <TextBlock Text="还没有会话" FontSize="18" FontWeight="Medium"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource AppTextPrimaryBrush}"/>
            <TextBlock Text="点击下方按钮开始新的对话"
                       HorizontalAlignment="Center"
                       Classes="caption"/>
          </StackPanel>

          <!-- 主按钮 -->
          <Button Command="{Binding NewConversationCommand}"
                  Classes="primary"
                  HorizontalAlignment="Center">
            <TextBlock Text="开始新对话" FontWeight="SemiBold"/>
          </Button>

          <!-- Quick Prompts -->
          <StackPanel Spacing="12" Margin="0,16,0,0" HorizontalAlignment="Center">
            <TextBlock Text="热门提示词:" 
                       Classes="caption"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>
            <ItemsControl ItemsSource="{Binding QuickPrompts}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="chip" Margin="4">
                    <Button Command="{Binding $parent[ItemsControl].((vm:ConversationListViewModel)DataContext).UseQuickPromptCommand}"
                            CommandParameter="{Binding}"
                            Background="Transparent" 
                            BorderThickness="0"
                            Padding="0">
                      <TextBlock Text="{Binding}" FontSize="13"/>
                    </Button>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </StackPanel>

        <!-- Conversation List -->
        <ItemsControl IsVisible="{Binding !IsEmpty}" 
                      ItemsSource="{Binding GroupedConversations}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:ConversationGroup">
              <StackPanel Spacing="8">
                <!-- 时间分组标题 -->
                <TextBlock Text="{Binding DateLabel}" 
                           Classes="section-title"
                           Margin="0,16,0,8"/>
                
                <!-- 会话列表 -->
                <ItemsControl ItemsSource="{Binding Conversations}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="model:Conversation">
                      <Border Classes="card" Margin="0,0,0,8">
                        <Button Command="{Binding #ConversationListControl.((vm:ConversationListViewModel)DataContext).SelectConversationCommand}"
                                CommandParameter="{Binding}"
                                Background="Transparent" 
                                BorderThickness="0"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Padding="0">
                          <Grid ColumnDefinitions="Auto, *, Auto" 
                                RowDefinitions="Auto, Auto, Auto">
                            <!-- 头像 (圆形 48x48) -->
                            <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                    Width="48" Height="48" 
                                    CornerRadius="24"
                                    Background="{DynamicResource PrimaryBrush}"
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Top">
                              <TextBlock Text="&#x1F916;" 
                                         HorizontalAlignment="Center" 
                                         VerticalAlignment="Center"
                                         FontSize="20"/>
                            </Border>
                            
                            <!-- 标题 -->
                            <TextBlock Grid.Row="0" Grid.Column="1" 
                                       Text="{Binding Title}"
                                       FontWeight="Medium" 
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1"
                                       Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                            
                            <!-- 预览 -->
                            <TextBlock Grid.Row="1" Grid.Column="1" 
                                       Text="{Binding Preview}"
                                       Classes="caption"
                                       TextTrimming="CharacterEllipsis" 
                                       MaxLines="1"/>
                            
                            <!-- 模型标签 -->
                            <Border Grid.Row="2" Grid.Column="1"
                                    Classes="tag"
                                    HorizontalAlignment="Left"
                                    Margin="0,4,0,0">
                              <TextBlock Text="{Binding ModelName}"
                                         FontSize="10"
                                         Foreground="{DynamicResource PrimaryBrush}"/>
                            </Border>
                            
                            <!-- 时间 -->
                            <TextBlock Grid.Row="0" Grid.Column="2" 
                                       Text="{Binding UpdatedAt, StringFormat='{}{0:HH:mm}'}"
                                       Classes="timestamp"
                                       VerticalAlignment="Top"
                                       Margin="8,0,0,0"/>
                          </Grid>
                        </Button>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>

    <!-- FAB 悬浮按钮 -->
    <Button Grid.Row="1" 
            Command="{Binding NewConversationCommand}"
            Classes="fab"
            HorizontalAlignment="Right" 
            VerticalAlignment="Bottom"
            Margin="0,0,20,20"
            IsVisible="{Binding !IsEmpty}">
      <TextBlock Text="+" FontSize="28" FontWeight="Bold" 
                 Margin="0,-4,0,0"/>
    </Button>

    <!-- Bottom Navigation -->
    <Border Grid.Row="2" 
            Background="{DynamicResource AppSurfaceBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="0,1,0,0" 
            Padding="16,12" Height="60">
      <Grid ColumnDefinitions="*, *">
        <!-- 会话 Tab (选中) -->
        <Button Grid.Column="0" 
                HorizontalAlignment="Center" 
                Background="Transparent"
                BorderThickness="0"
                Padding="16,8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="&#x1F4AC;" FontSize="18"/>
            <TextBlock Text="会话" FontWeight="Medium"
                       Foreground="{DynamicResource PrimaryBrush}"/>
          </StackPanel>
        </Button>
        
        <!-- 设置 Tab -->
        <Button Grid.Column="1" 
                Command="{Binding OpenSettingsCommand}"
                HorizontalAlignment="Center" 
                Background="Transparent"
                BorderThickness="0"
                Padding="16,8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="&#x2699;" FontSize="18"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"/>
            <TextBlock Text="设置"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"/>
          </StackPanel>
        </Button>
      </Grid>
    </Border>
  </Grid>
</UserControl>