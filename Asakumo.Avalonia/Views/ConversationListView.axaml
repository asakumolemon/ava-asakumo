<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Asakumo.Avalonia.ViewModels"
             xmlns:model="using:Asakumo.Avalonia.Models"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:Class="Asakumo.Avalonia.Views.ConversationListView"
             x:DataType="vm:ConversationListViewModel">

  <Grid RowDefinitions="Auto, *, Auto, Auto">
    <!-- Header -->
    <Border Grid.Row="0" Background="{DynamicResource SystemChromeLowColor}"
            Padding="16,12">
      <Grid ColumnDefinitions="*, Auto">
        <TextBlock Grid.Column="0" Text="Asakumo" FontSize="20" FontWeight="Bold"
                   VerticalAlignment="Center"/>
        <Button Grid.Column="1" Command="{Binding OpenSettingsCommand}"
                Background="Transparent" BorderThickness="0"
                Padding="8">
          <TextBlock Text="⚙️" FontSize="18"/>
        </Button>
      </Grid>
    </Border>

    <!-- Content -->
    <ScrollViewer Grid.Row="1">
      <StackPanel Spacing="16" Margin="16">
        <!-- Empty State -->
        <StackPanel IsVisible="{Binding IsEmpty}" VerticalAlignment="Center"
                    HorizontalAlignment="Center" Spacing="20" Margin="0,80,0,0">
          <TextBlock Text="📝" FontSize="48" HorizontalAlignment="Center"/>
          <TextBlock Text="还没有会话" FontSize="18" FontWeight="Medium"
                     HorizontalAlignment="Center"/>
          <TextBlock Text="点击下方按钮开始新的对话"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>

          <Button Command="{Binding NewConversationCommand}"
                  HorizontalAlignment="Center" HorizontalContentAlignment="Center"
                  MinWidth="180" Padding="20,12"
                  CornerRadius="20"
                  Background="{DynamicResource SystemAccentColor}"
                  Foreground="White">
            <TextBlock Text="开始新对话" FontWeight="SemiBold"/>
          </Button>

          <!-- Quick Prompts -->
          <StackPanel Spacing="8" Margin="0,20,0,0">
            <TextBlock Text="热门提示词:" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       Margin="0,0,0,8"/>
            <ItemsControl ItemsSource="{Binding QuickPrompts}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Command="{Binding $parent[ItemsControl].((vm:ConversationListViewModel)DataContext).UseQuickPromptCommand}"
                          CommandParameter="{Binding}"
                          Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                          CornerRadius="15" Padding="12,6" Margin="4">
                    <TextBlock Text="{Binding}" FontSize="12"/>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </StackPanel>

        <!-- Conversation List -->
        <ItemsControl IsVisible="{Binding !IsEmpty}" ItemsSource="{Binding GroupedConversations}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:ConversationGroup">
              <StackPanel Spacing="8">
                <TextBlock Text="{Binding DateLabel}" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           Margin="0,16,0,4"/>
                <ItemsControl ItemsSource="{Binding Conversations}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="model:Conversation">
                      <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                              CornerRadius="12" Padding="12" Margin="0,4,0,4">
                        <Button Command="{Binding $parent[ItemsControl].((vm:ConversationListViewModel)DataContext).SelectConversationCommand}"
                                CommandParameter="{Binding}"
                                Background="Transparent" BorderThickness="0"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left">
                          <Grid ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto, Auto, Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="[🤖]" Margin="0,0,8,0"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Title}"
                                       FontWeight="Medium" TextTrimming="CharacterEllipsis"
                                       MaxLines="1"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Preview}"
                                       FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                       TextTrimming="CharacterEllipsis" MaxLines="1"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding ModelName}"
                                       FontSize="10" Margin="8,0,0,0"
                                       Foreground="{DynamicResource SystemAccentColor}"/>
                          </Grid>
                        </Button>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>

    <!-- FAB -->
    <Button Grid.Row="2" Command="{Binding NewConversationCommand}"
            HorizontalAlignment="Right" VerticalAlignment="Bottom"
            Margin="0,0,16,16"
            Width="56" Height="56" CornerRadius="28"
            Background="{DynamicResource SystemAccentColor}"
            Foreground="White"
            IsVisible="{Binding !IsEmpty}">
      <TextBlock Text="+" FontSize="24" FontWeight="Bold"/>
    </Button>

    <!-- Bottom Navigation -->
    <Border Grid.Row="3" Background="{DynamicResource SystemChromeLowColor}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            BorderThickness="0,1,0,0" Padding="16,8">
      <Grid ColumnDefinitions="*, *">
        <Button Grid.Column="0" HorizontalAlignment="Center" Background="Transparent"
                BorderThickness="0">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="💬"/>
            <TextBlock Text="会话" FontWeight="Medium"/>
          </StackPanel>
        </Button>
        <Button Grid.Column="1" Command="{Binding OpenSettingsCommand}"
                HorizontalAlignment="Center" Background="Transparent"
                BorderThickness="0">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="⚙️"/>
            <TextBlock Text="设置"/>
          </StackPanel>
        </Button>
      </Grid>
    </Border>
  </Grid>
</UserControl>
