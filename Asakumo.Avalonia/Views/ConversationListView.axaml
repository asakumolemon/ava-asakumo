<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Asakumo.Avalonia.ViewModels"
             xmlns:model="using:Asakumo.Avalonia.Models"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:Class="Asakumo.Avalonia.Views.ConversationListView"
             x:DataType="vm:ConversationListViewModel"
             x:Name="ConversationListControl"
             Background="{DynamicResource AppBackgroundBrush}">

  <Grid RowDefinitions="Auto, *, Auto">
    <!-- Header -->
    <Border Grid.Row="0" Background="{DynamicResource AppBackgroundBrush}"
            Padding="16,16" Height="60">
      <Grid ColumnDefinitions="*, Auto">
        <TextBlock Grid.Column="0" Text="Asakumo" 
                   Classes="page-title"
                   VerticalAlignment="Center"/>
        <Button Grid.Column="1" Command="{Binding OpenSettingsCommand}"
                Classes="icon">
          <TextBlock Text="&#x2699;" FontSize="20"/>
        </Button>
      </Grid>
    </Border>

    <!-- Content -->
    <ScrollViewer Grid.Row="1">
      <StackPanel Spacing="16" Margin="16">
        <!-- Empty State -->
        <StackPanel IsVisible="{Binding IsEmpty}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="32"
                    Margin="0,40,0,0">
          <!-- 现代插图区域 -->
          <Border Width="120" Height="120"
                  CornerRadius="60"
                  Background="{DynamicResource AppSurfaceBrush}"
                  HorizontalAlignment="Center">
            <Grid>
              <!-- 聊天气泡图标 -->
              <PathIcon Data="M20,2H4A2,2 0 0,0 2,4V22L6,18H20A2,2 0 0,0 22,16V4A2,2 0 0,0 20,2M20,16H6L4,18V4H20V16Z"
                        Width="48" Height="48"
                        Foreground="{DynamicResource PrimaryBrush}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
              <!-- 装饰点 -->
              <Border Width="16" Height="16"
                      CornerRadius="8"
                      Background="{DynamicResource SuccessBrush}"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Margin="0,20,20,0"/>
            </Grid>
          </Border>

          <!-- 文字内容 -->
          <StackPanel Spacing="8" HorizontalAlignment="Center">
            <TextBlock Text="还没有会话"
                       FontSize="20"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource AppTextPrimaryBrush}"/>
            <TextBlock Text="点击下方按钮开始与 AI 对话"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                       Opacity="0.8"/>
          </StackPanel>

          <!-- 主按钮 -->
          <Button Command="{Binding NewConversationCommand}"
                  Classes="primary"
                  HorizontalAlignment="Center"
                  MinWidth="160"
                  Height="48"
                  CornerRadius="24">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <PathIcon Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"
                        Width="20" Height="20"
                        Foreground="White"/>
              <TextBlock Text="开始新对话"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <!-- Quick Prompts -->
          <StackPanel Spacing="16"
                      Margin="0,24,0,0"
                      HorizontalAlignment="Center"
                      MaxWidth="320">
            <TextBlock Text="试试这些提示词"
                       FontSize="12"
                       FontWeight="Medium"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                       Opacity="0.7"/>
            <ItemsControl ItemsSource="{Binding QuickPrompts}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"
                             HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="{DynamicResource AppSurfaceBrush}"
                          CornerRadius="16"
                          BorderBrush="{DynamicResource AppBorderBrush}"
                          BorderThickness="1"
                          Margin="4"
                          Padding="12,8">
                    <Button Command="{Binding $parent[ItemsControl].((vm:ConversationListViewModel)DataContext).UseQuickPromptCommand}"
                            CommandParameter="{Binding}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0">
                      <TextBlock Text="{Binding}"
                                 FontSize="13"
                                 Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                    </Button>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </StackPanel>

        <!-- Conversation List -->
        <ItemsControl IsVisible="{Binding !IsEmpty}" 
                      ItemsSource="{Binding GroupedConversations}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:ConversationGroup">
              <StackPanel Spacing="8">
                <!-- 时间分组标题 -->
                <TextBlock Text="{Binding DateLabel}" 
                           Classes="section-title"
                           Margin="0,16,0,8"/>
                
                <!-- 会话列表 -->
                <ItemsControl ItemsSource="{Binding Conversations}"
                              x:Name="ConversationsList">
                  <ItemsControl.Styles>
                    <!-- Swipe Action Button Style -->
                    <Style Selector="Button.swipe-action">
                      <Setter Property="Width" Value="72"/>
                      <Setter Property="Height" Value="72"/>
                      <Setter Property="Background" Value="Transparent"/>
                      <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                  </ItemsControl.Styles>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="model:Conversation">
                      <!-- Swipe Container -->
                      <Grid Height="72" Margin="0,0,0,1">
                        <!-- Background Actions (revealed on swipe) -->
                        <Grid ColumnDefinitions="Auto, *, Auto"
                              x:Name="SwipeActionsBackground">
                          <!-- Left Action: Pin -->
                          <Border Grid.Column="0"
                                  Background="{DynamicResource PrimaryBrush}"
                                  Width="72"
                                  HorizontalAlignment="Left">
                            <Button Classes="swipe-action"
                                    Command="{Binding #ConversationListControl.((vm:ConversationListViewModel)DataContext).PinConversationCommand}"
                                    CommandParameter="{Binding}">
                              <PathIcon Data="M16,12V4H17V2H7V4H8V12L6,14V16H11.2V22H12.8V16H18V14L16,12Z"
                                        Width="20" Height="20"
                                        Foreground="White"/>
                            </Button>
                          </Border>
                          <!-- Right Action: Delete -->
                          <Border Grid.Column="2"
                                  Background="{DynamicResource ErrorBrush}"
                                  Width="72"
                                  HorizontalAlignment="Right">
                            <Button Classes="swipe-action"
                                    Command="{Binding #ConversationListControl.((vm:ConversationListViewModel)DataContext).DeleteConversationCommand}"
                                    CommandParameter="{Binding}">
                              <PathIcon Data="M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19M8,9H16V19H8V9M15.5,4L14.5,3H9.5L8.5,4H5V6H19V4H15.5Z"
                                        Width="20" Height="20"
                                        Foreground="White"/>
                            </Button>
                          </Border>
                        </Grid>

                        <!-- Foreground Content -->
                        <Border x:Name="SwipeContent"
                                Background="{DynamicResource AppCardBrush}"
                                PointerPressed="OnSwipePointerPressed"
                                PointerMoved="OnSwipePointerMoved"
                                PointerReleased="OnSwipePointerReleased">
                          <Button Command="{Binding #ConversationListControl.((vm:ConversationListViewModel)DataContext).SelectConversationCommand}"
                                  CommandParameter="{Binding}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch"
                                  Padding="16,0">
                            <!-- Material Design 3: Three-column layout -->
                            <Grid ColumnDefinitions="Auto, *, Auto"
                                  Height="72">
                              <!-- Avatar Column (56dp according to Material Design) -->
                              <Grid Grid.Column="0"
                                    Width="56"
                                    VerticalAlignment="Center">
                                <Border Width="48" Height="48"
                                        CornerRadius="24"
                                        Background="{DynamicResource PrimaryBrush}">
                                  <TextBlock Text="AI"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             FontSize="16"
                                             FontWeight="SemiBold"
                                             Foreground="White"/>
                                </Border>
                                <!-- Online/Pinned Indicator -->
                                <Border Width="12" Height="12"
                                        CornerRadius="6"
                                        Background="{DynamicResource SuccessBrush}"
                                        BorderBrush="{DynamicResource AppCardBrush}"
                                        BorderThickness="2"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,2,2"
                                        IsVisible="{Binding IsPinned}"/>
                              </Grid>

                              <!-- Content Column -->
                              <StackPanel Grid.Column="1"
                                          VerticalAlignment="Center"
                                          Margin="16,0,16,0"
                                          Spacing="4">
                                <!-- Title -->
                                <TextBlock Text="{Binding Title}"
                                           FontSize="16"
                                           FontWeight="Medium"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                                <!-- Preview -->
                                <TextBlock Text="{Binding Preview}"
                                           FontSize="14"
                                           Opacity="0.6"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           MaxHeight="20"
                                           Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                              </StackPanel>

                              <!-- Trailing Column: Time + Badge -->
                              <StackPanel Grid.Column="2"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Right"
                                          Spacing="6">
                                <!-- Time -->
                                <TextBlock Text="{Binding UpdatedAt, StringFormat='{}{0:HH:mm}'}"
                                           FontSize="12"
                                           Opacity="0.5"
                                           Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                                <!-- Unread Badge -->
                                <Border Width="20" Height="20"
                                        CornerRadius="10"
                                        Background="{DynamicResource PrimaryBrush}"
                                        HorizontalAlignment="Right"
                                        IsVisible="{Binding HasUnread}">
                                  <TextBlock Text="{Binding UnreadCount}"
                                             FontSize="11"
                                             FontWeight="SemiBold"
                                             Foreground="White"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                                </Border>
                              </StackPanel>
                            </Grid>
                          </Button>
                        </Border>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>

    <!-- FAB 悬浮按钮 -->
    <Button Grid.Row="1" 
            Command="{Binding NewConversationCommand}"
            Classes="fab"
            HorizontalAlignment="Right" 
            VerticalAlignment="Bottom"
            Margin="0,0,20,20"
            IsVisible="{Binding !IsEmpty}">
      <TextBlock Text="+" FontSize="28" FontWeight="Bold" 
                 Margin="0,-4,0,0"/>
    </Button>

    <!-- Bottom Navigation -->
    <Border Grid.Row="2" 
            Background="{DynamicResource AppSurfaceBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="0,1,0,0" 
            Padding="16,12" Height="60">
      <Grid ColumnDefinitions="*, *">
        <!-- 会话 Tab (选中) -->
        <Button Grid.Column="0" 
                HorizontalAlignment="Center" 
                Background="Transparent"
                BorderThickness="0"
                Padding="16,8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="&#x1F4AC;" FontSize="18"/>
            <TextBlock Text="会话" FontWeight="Medium"
                       Foreground="{DynamicResource PrimaryBrush}"/>
          </StackPanel>
        </Button>
        
        <!-- 设置 Tab -->
        <Button Grid.Column="1" 
                Command="{Binding OpenSettingsCommand}"
                HorizontalAlignment="Center" 
                Background="Transparent"
                BorderThickness="0"
                Padding="16,8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="&#x2699;" FontSize="18"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"/>
            <TextBlock Text="设置"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"/>
          </StackPanel>
        </Button>
      </Grid>
    </Border>
  </Grid>
</UserControl>