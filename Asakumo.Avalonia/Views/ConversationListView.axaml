<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Asakumo.Avalonia.ViewModels"
             xmlns:model="using:Asakumo.Avalonia.Models"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:Class="Asakumo.Avalonia.Views.ConversationListView"
             x:DataType="vm:ConversationListViewModel"
             x:Name="ConversationListControl"
             Background="{DynamicResource AppBackgroundBrush}">

  <Grid RowDefinitions="Auto, *">
    <!-- Header - MD3 Top App Bar -->
    <Border Grid.Row="0"
            Classes="top-app-bar">
      <Grid ColumnDefinitions="Auto, *, Auto"
            Margin="16,0">
        <!-- Logo -->
        <Border Grid.Column="0"
                Classes="app-logo"
                VerticalAlignment="Center">
          <TextBlock Text="&#x1F319;"
                     FontSize="20"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Border>

        <!-- Spacer -->
        <Border Grid.Column="1"/>

        <!-- Action Button -->
        <Button Grid.Column="2"
                Command="{Binding OpenSettingsCommand}"
                Classes="icon"
                VerticalAlignment="Center">
          <PathIcon Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                    Width="24" Height="24"
                    Foreground="{DynamicResource SilverMistBrush}"/>
        </Button>
      </Grid>
    </Border>

    <!-- Content -->
    <ScrollViewer Grid.Row="1">
      <StackPanel Spacing="16" Margin="16">
        <!-- Empty State -->
        <StackPanel IsVisible="{Binding IsEmpty}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="32"
                    Margin="0,40,0,0">
          <!-- Illustration -->
          <Border Classes="empty-state-illustration"
                  HorizontalAlignment="Center">
            <Grid>
              <PathIcon Data="M20,2H4A2,2 0 0,0 2,4V22L6,18H20A2,2 0 0,0 22,16V4A2,2 0 0,0 20,2M20,16H6L4,18V4H20V16Z"
                        Width="48" Height="48"
                        Foreground="{DynamicResource PrimaryBrush}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
              <Border Width="16" Height="16"
                      CornerRadius="8"
                      Background="{DynamicResource SuccessBrush}"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Margin="0,20,20,0"/>
            </Grid>
          </Border>

          <!-- Text Content -->
          <StackPanel Spacing="8" HorizontalAlignment="Center">
            <TextBlock Text="还没有会话"
                       Classes="empty-state-title"/>
            <TextBlock Text="点击下方按钮开始与 AI 对话"
                       Classes="empty-state-subtitle"/>
          </StackPanel>

          <!-- Primary Button -->
          <Button Command="{Binding NewConversationCommand}"
                  Classes="btn-filled"
                  HorizontalAlignment="Center"
                  MinWidth="160">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <PathIcon Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"
                        Width="20" Height="20"
                        Foreground="#08101F"/>
              <TextBlock Text="开始新对话"
                         FontWeight="SemiBold"
                         Foreground="#08101F"
                         VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <!-- Quick Prompts -->
          <StackPanel Spacing="16"
                      Margin="0,24,0,0"
                      HorizontalAlignment="Center"
                      MaxWidth="320">
            <TextBlock Text="试试这些提示词"
                       FontSize="12"
                       FontWeight="Medium"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource AppTextTertiaryBrush}"/>
            <ItemsControl ItemsSource="{Binding QuickPrompts}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"
                             HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="quick-prompt-chip">
                    <Button Command="{Binding $parent[ItemsControl].((vm:ConversationListViewModel)DataContext).UseQuickPromptCommand}"
                            CommandParameter="{Binding}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0">
                      <TextBlock Text="{Binding}"
                                 Classes="quick-prompt-text"/>
                    </Button>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </StackPanel>

        <!-- Conversation List -->
        <ItemsControl IsVisible="{Binding !IsEmpty}" 
                      ItemsSource="{Binding GroupedConversations}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:ConversationGroup">
              <StackPanel Spacing="8">
                <!-- 时间分组标题 -->
                <TextBlock Text="{Binding DateLabel}"
                           Classes="section-title"
                           Margin="0,16,0,8"/>

                <!-- 会话列表 -->
                <ItemsControl ItemsSource="{Binding Conversations}"
                              x:Name="ConversationsList">
                  <ItemsControl.Styles>
                    <!-- Swipe Action Button Style -->
                    <Style Selector="Button.swipe-action">
                      <Setter Property="Width" Value="72"/>
                      <Setter Property="Height" Value="72"/>
                      <Setter Property="Background" Value="Transparent"/>
                      <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                  </ItemsControl.Styles>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="model:Conversation">
                      <!-- Swipe Container -->
                      <Grid Height="72" Margin="0,0,0,1">
                        <!-- Background Actions (revealed on swipe) -->
                        <Grid ColumnDefinitions="Auto, *, Auto"
                              x:Name="SwipeActionsBackground">
                          <!-- Left Action: Pin -->
                          <Border Grid.Column="0"
                                  Background="{DynamicResource PrimaryBrush}"
                                  Width="72"
                                  HorizontalAlignment="Left">
                            <Button Classes="swipe-action"
                                    Command="{Binding #ConversationListControl.((vm:ConversationListViewModel)DataContext).PinConversationCommand}"
                                    CommandParameter="{Binding}">
                              <PathIcon Data="M16,12V4H17V2H7V4H8V12L6,14V16H11.2V22H12.8V16H18V14L16,12Z"
                                        Width="20" Height="20"
                                        Foreground="#08101F"/>
                            </Button>
                          </Border>
                          <!-- Right Action: Delete -->
                          <Border Grid.Column="2"
                                  Background="{DynamicResource ErrorBrush}"
                                  Width="72"
                                  HorizontalAlignment="Right">
                            <Button Classes="swipe-action"
                                    Command="{Binding #ConversationListControl.((vm:ConversationListViewModel)DataContext).DeleteConversationCommand}"
                                    CommandParameter="{Binding}">
                              <PathIcon Data="M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19M8,9H16V19H8V9M15.5,4L14.5,3H9.5L8.5,4H5V6H19V4H15.5Z"
                                        Width="20" Height="20"
                                        Foreground="White"/>
                            </Button>
                          </Border>
                        </Grid>

                        <!-- Foreground Content -->
                        <Border x:Name="SwipeContent"
                                Classes="list-item"
                                PointerPressed="OnSwipePointerPressed"
                                PointerMoved="OnSwipePointerMoved"
                                PointerReleased="OnSwipePointerReleased">
                          <Button Command="{Binding #ConversationListControl.((vm:ConversationListViewModel)DataContext).SelectConversationCommand}"
                                  CommandParameter="{Binding}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch"
                                  Padding="16,0">
                            <!-- MD3 Three-column layout -->
                            <Grid ColumnDefinitions="Auto, *, Auto"
                                  Height="72">
                              <!-- Avatar Column -->
                              <Grid Grid.Column="0"
                                    Width="56"
                                    VerticalAlignment="Center">
                                <Border Classes="list-item-avatar">
                                  <TextBlock Text="AI"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             FontSize="16"
                                             FontWeight="SemiBold"
                                             Foreground="#08101F"/>
                                </Border>
                                <!-- Pinned Indicator -->
                                <Border Classes="pinned-indicator"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,2,2"
                                        IsVisible="{Binding IsPinned}"/>
                              </Grid>

                              <!-- Content Column -->
                              <StackPanel Grid.Column="1"
                                          VerticalAlignment="Center"
                                          Margin="16,0,16,0"
                                          Spacing="4">
                                <!-- Title -->
                                <TextBlock Text="{Binding Title}"
                                           FontSize="16"
                                           FontWeight="Medium"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                                <!-- Preview -->
                                <TextBlock Text="{Binding Preview}"
                                           FontSize="14"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           MaxHeight="20"
                                           Foreground="{DynamicResource AppTextTertiaryBrush}"/>
                              </StackPanel>

                              <!-- Trailing Column: Time + Badge -->
                              <StackPanel Grid.Column="2"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Right"
                                          Spacing="6">
                                <!-- Time -->
                                <TextBlock Text="{Binding UpdatedAt, StringFormat='{}{0:HH:mm}'}"
                                           FontSize="12"
                                           Foreground="{DynamicResource AppTextTertiaryBrush}"/>
                                <!-- Unread Badge -->
                                <Border Classes="unread-badge"
                                        IsVisible="{Binding HasUnread}">
                                  <TextBlock Text="{Binding UnreadCount}"
                                             Classes="unread-badge-text"/>
                                </Border>
                              </StackPanel>
                            </Grid>
                          </Button>
                        </Border>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>

    <!-- FAB - MD3 Specification -->
    <Button Grid.Row="1"
            Command="{Binding NewConversationCommand}"
            Classes="fab"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,16,16"
            IsVisible="{Binding !IsEmpty}">
      <PathIcon Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"
                Width="24" Height="24"
                Foreground="#08101F"/>
    </Button>
  </Grid>
</UserControl>
